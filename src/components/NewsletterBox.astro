---
---

<div id="newsletter" class="relative bg-gradient-to-br from-slate-900 via-slate-950 to-slate-900 text-white rounded-2xl overflow-hidden shadow-xl p-8 md:p-12 border border-slate-800/60">
  <!-- Subtle gradient glows -->
  <div class="absolute -right-20 -top-20 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl animate-glow-pulse pointer-events-none"></div>
  <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-violet-500/10 rounded-full blur-3xl animate-glow-pulse [animation-delay:3s] pointer-events-none"></div>
  
  <!-- Subtle technical grid overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:16px_16px] pointer-events-none"></div>

  <div class="relative max-w-2xl mx-auto text-center z-10">
    <span class="text-xs uppercase tracking-widest font-black text-indigo-400">Stay Ahead of the Curve</span>
    <h2 class="text-2xl md:text-3.5xl font-black font-serif mt-2 mb-4 tracking-tight">Subscribe to the Mershal Newsletter</h2>
    <p class="text-slate-400 text-sm md:text-base mb-8 max-w-lg mx-auto leading-relaxed">
      Get hand-picked AI tools, in-depth SaaS comparisons, and business automation tips delivered directly to your inbox. No spam, unsubscribe anytime.
    </p>
    
    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        id="newsletter-email"
        required
        placeholder="Enter your professional email"
        class="flex-1 bg-slate-950/60 backdrop-blur-md border border-slate-800 text-white placeholder-slate-500 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all duration-200"
      />
      <button
        type="submit"
        id="newsletter-submit"
        class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-xl text-sm transition-all duration-200 shadow-lg hover:shadow-indigo-600/25 active:scale-[0.98] cursor-pointer"
      >
        Join Free
      </button>
    </form>
    
    <div id="newsletter-status" class="hidden mt-4 text-xs font-semibold"></div>
  </div>
</div>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
  const submitBtn = document.getElementById('newsletter-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('newsletter-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Subscribing...';
    statusEl.classList.add('hidden');

    try {
      // Dynamic lazy load of Firebase client SDK
      const { db } = await import('../lib/firebase');
      const { collection, addDoc, serverTimestamp } = await import('firebase/firestore');

      // Save subscription doc directly to Firestore collection
      await addDoc(collection(db, 'newsletter_subscribers'), {
        email: email,
        subscribed_at: serverTimestamp(),
        status: 'active'
      });

      statusEl.textContent = '✓ Welcome to Mershal! You have successfully subscribed.';
      statusEl.className = 'mt-4 text-xs font-semibold text-emerald-400';
      statusEl.classList.remove('hidden');
      form.reset();
    } catch (error: any) {
      console.error('Newsletter subscription error:', error);
      statusEl.textContent = '✗ Subscription failed. Please try again later.';
      statusEl.className = 'mt-4 text-xs font-semibold text-red-400';
      statusEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Join Free';
    }
  });
</script>
