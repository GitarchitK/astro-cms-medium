---
const categories = [
  { name: 'AI Tools', href: '/category/ai-tools' },
  { name: 'Technology Guides', href: '/category/technology-guides' },
  { name: 'Software Reviews', href: '/category/software-reviews' },
  { name: 'SEO & Blogging', href: '/category/seo-blogging' },
  { name: 'Web Development', href: '/category/web-development' },
  { name: 'Productivity', href: '/category/productivity' },
  { name: 'Freelancing', href: '/category/freelancing' },
  { name: 'Side Hustles', href: '/category/side-hustles' },
  { name: 'Remote Work', href: '/category/remote-work' },
  { name: 'Startup Stories', href: '/category/startup-stories' }
];
---

<header class="sticky top-0 z-50 bg-white dark:bg-slate-950 border-b border-slate-100 dark:border-slate-900 transition-colors duration-200">
  <!-- Main Navigation Row -->
  <div class="container mx-auto px-4 max-w-6xl flex items-center justify-between h-14 md:h-16">
    
    <!-- Left Section: Logo -->
    <div class="flex items-center gap-6">
      <button id="mobile-menu-btn" class="lg:hidden text-slate-500 hover:text-slate-900 dark:hover:text-white p-2 rounded-lg transition" aria-label="Open Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <!-- Typographic Serif Logo (Medium Style) -->
      <a href="/" class="flex items-center gap-1 group shrink-0">
        <span class="text-2xl font-serif font-black tracking-tight text-slate-900 dark:text-white transition-colors">Mershal</span>
        <span class="w-2 h-2 rounded-full bg-slate-900 dark:bg-indigo-400 mt-2.5"></span>
      </a>
      
      <!-- Desktop Quick links -->
      <nav class="hidden lg:flex items-center gap-1.5 ml-4">
        <a href="/about" class="px-3 py-1.5 text-xs font-semibold text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">Our Story</a>
        <a href="/contact" class="px-3 py-1.5 text-xs font-semibold text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">Contact</a>
      </nav>
    </div>

    <!-- Right Section: Actions -->
    <div class="flex items-center gap-1.5 md:gap-3">
      <!-- Search Input (Compact) -->
      <div id="search-trigger-bar" class="hidden md:flex items-center gap-2 bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-full px-3.5 py-1.5 w-44 lg:w-52 cursor-pointer transition-all duration-150">
        <svg class="w-3.5 h-3.5 text-slate-400 dark:text-slate-550" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-xs text-slate-400 dark:text-slate-500 select-none font-medium">Search...</span>
      </div>
      
      <button id="search-trigger-mobile" class="md:hidden text-slate-500 hover:text-slate-900 dark:hover:text-white p-2 rounded-lg transition" aria-label="Search">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </button>

      <!-- Theme Switcher -->
      <button id="dark-mode-toggle" class="text-slate-500 hover:text-slate-900 dark:hover:text-white p-2 rounded-lg transition cursor-pointer" aria-label="Toggle Theme">
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
        <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Category List Scrollbar Nav -->
  <div class="border-t border-slate-100 dark:border-slate-900 py-2">
    <div class="container mx-auto px-4 max-w-6xl flex items-center justify-between min-w-0">
      <nav class="flex-1 min-w-0 overflow-x-auto whitespace-nowrap scrollbar-none flex items-center gap-1.5">
        {categories.map(cat => (
          <a
            href={cat.href}
            class="relative px-3 py-1 text-[11px] font-bold text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors duration-150 group"
          >
            {cat.name}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Mobile Dropdown -->
  <div id="mobile-nav" class="lg:hidden hidden border-t border-slate-100 dark:border-slate-900 bg-white dark:bg-slate-950 shadow-sm max-h-[85vh] overflow-y-auto">
    <div class="p-4 space-y-1">
      <a href="/" class="block px-4 py-2.5 rounded-lg text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-350 hover:bg-slate-50 dark:hover:bg-slate-900 transition">Home</a>
      <a href="/about" class="block px-4 py-2.5 rounded-lg text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-350 hover:bg-slate-50 dark:hover:bg-slate-900 transition">Our Story</a>
      <a href="/contact" class="block px-4 py-2.5 rounded-lg text-xs font-bold uppercase tracking-wider text-slate-600 dark:text-slate-350 hover:bg-slate-50 dark:hover:bg-slate-900 transition">Contact</a>
      {categories.map(cat => (
        <a href={cat.href} class="block px-4 py-2.5 rounded-lg text-xs font-semibold text-slate-500 hover:bg-slate-50 dark:hover:bg-slate-900 transition">
          {cat.name}
        </a>
      ))}
    </div>
  </div>

  <!-- Search Modal -->
  <div id="search-modal" class="fixed inset-0 z-[100] bg-slate-950/20 dark:bg-slate-950/40 backdrop-blur-sm flex items-start justify-center pt-[15vh] px-4 hidden">
    <div class="bg-white/95 dark:bg-slate-900/95 rounded-2xl shadow-xl w-full max-w-xl overflow-hidden border border-slate-200/50 dark:border-slate-800/50 animate-in fade-in zoom-in-95 duration-150">
      <div class="p-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-3 bg-slate-50/20">
        <svg class="w-4 h-4 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="Search Mershal..."
          class="flex-1 bg-transparent text-sm focus:outline-none text-slate-800 dark:text-white placeholder-slate-450"
          autocomplete="off"
        />
        <button id="close-search" class="text-xs font-bold text-slate-400 hover:text-slate-605 bg-slate-100 dark:bg-slate-800 px-2.5 py-1.5 rounded-lg transition cursor-pointer">
          Esc
        </button>
      </div>
      <div id="search-results" class="max-h-[300px] overflow-y-auto p-2 divide-y divide-slate-100 dark:divide-slate-800 empty:hidden"></div>
      <div id="search-empty" class="p-8 text-center text-slate-400 dark:text-slate-500 text-xs font-bold uppercase tracking-wider">
        Type to search articles...
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile nav toggler
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  mobileBtn?.addEventListener('click', () => {
    mobileNav?.classList.toggle('hidden');
  });

  // Theme switch
  const themeToggle = document.getElementById('dark-mode-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Modal controller
  const searchTriggers = [
    document.getElementById('search-trigger-bar'),
    document.getElementById('search-trigger-mobile')
  ];
  const searchModal = document.getElementById('search-modal');
  const closeSearch = document.getElementById('close-search');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results');
  const emptyLabel = document.getElementById('search-empty');

  function openModal() {
    searchModal?.classList.remove('hidden');
    searchInput?.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    searchModal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  searchTriggers.forEach(btn => btn?.addEventListener('click', openModal));
  closeSearch?.addEventListener('click', closeModal);
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Fetch search matches
  let searchTimeout: any = null;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const query = searchInput.value.trim().toLowerCase();

    if (!query) {
      if (resultsContainer) resultsContainer.innerHTML = '';
      if (emptyLabel) {
        emptyLabel.classList.remove('hidden');
        emptyLabel.innerText = 'Type to search articles...';
      }
      return;
    }

    if (emptyLabel) emptyLabel.innerText = 'Searching...';

    searchTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/api/articles`);
        const articles = await res.json();
        
        const filtered = articles.filter((art: any) => 
          art.title.toLowerCase().includes(query) || 
          art.excerpt.toLowerCase().includes(query) ||
          art.category.toLowerCase().includes(query) ||
          (art.tags && art.tags.some((t: string) => t.toLowerCase().includes(query)))
        );

        if (resultsContainer) resultsContainer.innerHTML = '';

        if (filtered.length === 0) {
          if (emptyLabel) {
            emptyLabel.classList.remove('hidden');
            emptyLabel.innerText = 'No articles found matching query.';
          }
          return;
        }

        if (emptyLabel) emptyLabel.classList.add('hidden');

        filtered.slice(0, 5).forEach((art: any) => {
          const item = document.createElement('a');
          const categorySlug = (art.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-');
          item.href = `/${categorySlug}/${art.slug}`;
          item.className = 'block p-3 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-xl transition text-left';
          item.innerHTML = `
            <span class="block text-[10px] font-bold text-indigo-500 uppercase tracking-wide">${art.category}</span>
            <h4 class="text-sm font-bold text-slate-800 dark:text-white leading-tight line-clamp-1 mt-0.5">${art.title}</h4>
            <p class="text-xs text-slate-400 dark:text-slate-500 line-clamp-1 mt-0.5">${art.excerpt}</p>
          `;
          resultsContainer?.appendChild(item);
        });
      } catch (err) {
        console.error('Search query error:', err);
        if (emptyLabel) emptyLabel.innerText = 'Error occurred loading articles.';
      }
    }, 200);
  });
</script>

<style>
  /* Hide scrollbar for Category Navbar */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
