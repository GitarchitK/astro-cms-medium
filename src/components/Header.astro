---
import { adminDb } from '../lib/firebase-admin';

const categories = [
  { name: 'AI Tools', href: '/category/ai-tools' },
  { name: 'Technology Guides', href: '/category/technology-guides' },
  { name: 'Software Reviews', href: '/category/software-reviews' },
  { name: 'SEO & Blogging', href: '/category/seo-blogging' },
  { name: 'Web Development', href: '/category/web-development' },
  { name: 'Productivity', href: '/category/productivity' },
  { name: 'Freelancing', href: '/category/freelancing' },
  { name: 'Side Hustles', href: '/category/side-hustles' },
  { name: 'Remote Work', href: '/category/remote-work' },
  { name: 'Startup Stories', href: '/category/startup-stories' }
];

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Reviews', href: '/category/software-reviews' },
  { name: 'Best Software', href: '/category/ai-tools' },
  { name: 'Comparisons', href: '/category/startup-stories' },
  { name: 'Guides & Tutorials', href: '/category/technology-guides' },
  { name: 'News & Trends', href: '/category/seo-blogging' }
];

const { pathname } = Astro.url;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};

let latestArticles: any[] = [];
if (adminDb) {
  try {
    const snapshot = await adminDb.collection('articles')
      .where('status', '==', 'published')
      .orderBy('publish_date', 'desc')
      .limit(5)
      .get();
      
    const now = new Date();
    latestArticles = snapshot.docs.map(doc => {
      const d = doc.data();
      return {
        id: doc.id,
        slug: d.slug || doc.id,
        title: d.title || '',
        category: d.category || 'AI Tools',
        categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        publishDate: d.publish_date?.toDate?.() || null
      };
    })
    .filter(art => art.publishDate && art.publishDate <= now);
  } catch (e) {
    console.error('Header articles fetch error:', e);
  }
}
---

<header class="sticky top-0 z-50 bg-white dark:bg-slate-950 border-b border-slate-100 dark:border-slate-900 transition-colors duration-200">
  
  <!-- Level 1: Top Bar -->
  <div class="hidden md:block bg-slate-50 dark:bg-slate-900/60 border-b border-slate-100 dark:border-slate-800/50 py-2 transition-colors">
    <div class="container mx-auto px-4 max-w-6xl flex items-center justify-between text-[11px] font-medium font-outfit text-slate-550 dark:text-slate-400">
      <!-- Left Side: Links -->
      <div class="flex items-center gap-5">
        <a href="/about" class="hover:text-slate-900 dark:hover:text-white transition-colors">About Us</a>
        <a href="/contact" class="hover:text-slate-900 dark:hover:text-white transition-colors">Contact Us</a>
        <a href="/privacy" class="hover:text-slate-900 dark:hover:text-white transition-colors">Content Policy</a>
        <a href="/about#faq" class="hover:text-slate-900 dark:hover:text-white transition-colors">Frequently Asked Questions</a>
      </div>
      <!-- Right Side: Social Media Icons -->
      <div class="flex items-center gap-3">
        <a href="#" class="hover:text-blue-600 transition-colors" aria-label="Facebook" target="_blank">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1V12h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
        </a>
        <a href="#" class="hover:text-blue-400 transition-colors" aria-label="Twitter" target="_blank">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="#" class="hover:text-blue-700 transition-colors" aria-label="LinkedIn" target="_blank">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
        <a href="#" class="hover:text-red-600 transition-colors" aria-label="YouTube" target="_blank">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="#" class="hover:text-slate-900 dark:hover:text-white transition-colors" aria-label="GitHub" target="_blank">
          <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.577.688.479C19.138 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Level 2: Main Navigation Bar -->
  <div class="container mx-auto px-4 max-w-6xl flex items-center justify-between h-16 md:h-20 transition-all">
    <!-- Left: Brand Logo -->
    <div class="flex items-center gap-1.5 shrink-0">
      <svg class="w-6 h-6 text-red-650" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
      <a href="/" class="font-outfit font-black tracking-tight text-xl transition-colors flex items-center select-none">
        <span class="text-slate-850 dark:text-white uppercase">Mershal.</span>
        <span class="font-black flex items-center lowercase">
          <span style="color: #FF9933;">i</span>
          <span style="color: #138808;">n</span>
        </span>
      </a>
    </div>

    <!-- Middle: Categories / Page links -->
    <nav class="hidden lg:flex items-center gap-5 font-outfit text-xs font-bold tracking-wide uppercase select-none">
      {navLinks.map(link => {
        const active = isActive(link.href);
        return (
          <a
            href={link.href}
            class={`flex items-center gap-1 transition-colors duration-150 ${active ? 'text-red-650 font-extrabold' : 'text-slate-700 dark:text-slate-350 hover:text-slate-900 dark:hover:text-white'}`}
          >
            {active && <span class="text-[10px]">•</span>} {link.name}
          </a>
        );
      })}
    </nav>

    <!-- Right: Action Icons (Search, Hamburger, Dark Mode) -->
    <div class="flex items-center gap-1.5 md:gap-3">
      <!-- Search Button -->
      <button id="search-trigger-btn" class="text-slate-500 hover:text-slate-900 dark:hover:text-white p-2 rounded-lg transition cursor-pointer" aria-label="Search">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </button>
      
      <!-- Dark Mode Toggle -->
      <button id="dark-mode-toggle" class="text-slate-500 hover:text-slate-900 dark:hover:text-white p-2 rounded-lg transition cursor-pointer" aria-label="Toggle Theme">
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
        <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
        </svg>
      </button>

      <!-- Hamburger Menu Toggler -->
      <button id="mobile-menu-btn" class="lg:hidden text-slate-500 hover:text-slate-900 dark:hover:text-white p-2 rounded-lg transition cursor-pointer" aria-label="Open Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Level 3: Dynamic Interesting/Breaking Articles Banner -->
  {latestArticles.length > 0 && (
    <div class="container mx-auto px-4 max-w-6xl pb-4 animate-in fade-in duration-300">
      <div class="bg-blue-50/50 dark:bg-slate-900/30 border border-blue-100/40 dark:border-slate-800/35 p-2 rounded-lg flex items-center justify-between gap-4 font-outfit text-xs text-slate-700 dark:text-slate-350 select-none shadow-[0_1px_2px_rgba(0,0,0,0.01)]">
        <div class="flex items-center gap-3 overflow-hidden min-w-0 flex-1">
          <!-- Alert Badge: "Interesting:" -->
          <span class="px-2 py-0.5 rounded bg-red-650 text-white font-bold text-[9px] tracking-wide uppercase shrink-0">
            Interesting:
          </span>
          <!-- Dynamic Carousel Container -->
          <div class="relative overflow-hidden flex-1 h-4 min-w-0">
            {latestArticles.map((art, index) => (
              <a
                href={`/${art.categorySlug}/${art.slug}`}
                id={`carousel-item-${index}`}
                class={`absolute inset-0 truncate font-semibold text-slate-800 dark:text-slate-200 hover:text-red-650 dark:hover:text-red-650 transition-all duration-300 ${index === 0 ? 'opacity-100 translate-y-0 pointer-events-auto' : 'opacity-0 translate-y-4 pointer-events-none'}`}
              >
                {art.title}
              </a>
            ))}
          </div>
        </div>
        
        <!-- Navigation Arrows -->
        <div class="flex items-center gap-1 shrink-0">
          <button id="carousel-prev" class="w-4.5 h-4.5 rounded-full bg-white dark:bg-slate-850 hover:bg-slate-50 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-700/60 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white transition cursor-pointer" aria-label="Previous Article">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="carousel-next" class="w-4.5 h-4.5 rounded-full bg-white dark:bg-slate-850 hover:bg-slate-50 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-700/60 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-white transition cursor-pointer" aria-label="Next Article">
            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  )}

  <!-- Mobile Dropdown Nav -->
  <div id="mobile-nav" class="lg:hidden hidden border-t border-slate-100 dark:border-slate-900 bg-white dark:bg-slate-950 shadow-sm max-h-[85vh] overflow-y-auto">
    <div class="p-4 space-y-1">
      {navLinks.map(link => {
        const active = isActive(link.href);
        return (
          <a
            href={link.href}
            class={`block px-4 py-2.5 rounded-lg text-xs font-bold uppercase tracking-wider transition ${active ? 'text-red-650 bg-slate-50 dark:bg-slate-900' : 'text-slate-600 dark:text-slate-350 hover:bg-slate-50 dark:hover:bg-slate-900'}`}
          >
            {link.name}
          </a>
        );
      })}
      <div class="h-px bg-slate-100 dark:bg-slate-900 my-2"></div>
      <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest px-4 mb-2">Categories</p>
      {categories.map(cat => (
        <a href={cat.href} class="block px-4 py-2.5 rounded-lg text-xs font-semibold text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 transition">
          {cat.name}
        </a>
      ))}
    </div>
  </div>

  <!-- Search Modal -->
  <div id="search-modal" class="fixed inset-0 z-[100] bg-slate-950/20 dark:bg-slate-950/40 backdrop-blur-sm flex items-start justify-center pt-[15vh] px-4 hidden">
    <div class="bg-white/95 dark:bg-slate-900/95 rounded-2xl shadow-xl w-full max-w-xl overflow-hidden border border-slate-200/50 dark:border-slate-800/50 animate-in fade-in zoom-in-95 duration-150">
      <div class="p-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-3 bg-slate-50/20">
        <svg class="w-4 h-4 text-slate-400 dark:text-slate-550" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="Search Mershal..."
          class="flex-1 bg-transparent text-sm focus:outline-none text-slate-800 dark:text-white placeholder-slate-450"
          autocomplete="off"
        />
        <button id="close-search" class="text-xs font-bold text-slate-450 hover:text-slate-600 bg-slate-100 dark:bg-slate-800 px-2.5 py-1.5 rounded-lg transition cursor-pointer">
          Esc
        </button>
      </div>
      <div id="search-results" class="max-h-[300px] overflow-y-auto p-2 divide-y divide-slate-100 dark:divide-slate-800 empty:hidden"></div>
      <div id="search-empty" class="p-8 text-center text-slate-400 dark:text-slate-500 text-xs font-bold uppercase tracking-wider">
        Type to search articles...
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile nav toggler
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  mobileBtn?.addEventListener('click', () => {
    mobileNav?.classList.toggle('hidden');
  });

  // Theme switch
  const themeToggle = document.getElementById('dark-mode-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Modal controller
  const searchTriggers = [
    document.getElementById('search-trigger-btn'),
    document.getElementById('search-trigger-mobile')
  ];
  const searchModal = document.getElementById('search-modal');
  const closeSearch = document.getElementById('close-search');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results');
  const emptyLabel = document.getElementById('search-empty');

  function openModal() {
    searchModal?.classList.remove('hidden');
    searchInput?.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    searchModal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  searchTriggers.forEach(btn => btn?.addEventListener('click', openModal));
  closeSearch?.addEventListener('click', closeModal);
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Fetch search matches
  let searchTimeout: any = null;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const query = searchInput.value.trim().toLowerCase();

    if (!query) {
      if (resultsContainer) resultsContainer.innerHTML = '';
      if (emptyLabel) {
        emptyLabel.classList.remove('hidden');
        emptyLabel.innerText = 'Type to search articles...';
      }
      return;
    }

    if (emptyLabel) emptyLabel.innerText = 'Searching...';

    searchTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/api/articles`);
        const articles = await res.json();
        
        const filtered = articles.filter((art: any) => 
          art.title.toLowerCase().includes(query) || 
          art.excerpt.toLowerCase().includes(query) ||
          art.category.toLowerCase().includes(query) ||
          (art.tags && art.tags.some((t: string) => t.toLowerCase().includes(query)))
        );

        if (resultsContainer) resultsContainer.innerHTML = '';

        if (filtered.length === 0) {
          if (emptyLabel) {
            emptyLabel.classList.remove('hidden');
            emptyLabel.innerText = 'No articles found matching query.';
          }
          return;
        }

        if (emptyLabel) emptyLabel.classList.add('hidden');

        filtered.slice(0, 5).forEach((art: any) => {
          const item = document.createElement('a');
          const categorySlug = (art.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-');
          item.href = `/${categorySlug}/${art.slug}`;
          item.className = 'block p-3 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-xl transition text-left';
          item.innerHTML = `
            <span class="block text-[10px] font-bold text-indigo-500 uppercase tracking-wide">${art.category}</span>
            <h4 class="text-sm font-bold text-slate-800 dark:text-white leading-tight line-clamp-1 mt-0.5">${art.title}</h4>
            <p class="text-xs text-slate-400 dark:text-slate-550 line-clamp-1 mt-0.5">${art.excerpt}</p>
          `;
          resultsContainer?.appendChild(item);
        });
      } catch (err) {
        console.error('Search query error:', err);
        if (emptyLabel) emptyLabel.innerText = 'Error occurred loading articles.';
      }
    }, 200);
  });

  // Dynamic Breaking Alert Banner Carousel Controller
  let currentIndex = 0;
  const carouselItems = document.querySelectorAll('[id^="carousel-item-"]');
  const totalItems = carouselItems.length;

  function showItem(index: number) {
    carouselItems.forEach((item, idx) => {
      if (idx === index) {
        item.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        item.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      } else {
        item.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        item.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      }
    });
  }

  document.getElementById('carousel-prev')?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + totalItems) % totalItems;
    showItem(currentIndex);
  });

  document.getElementById('carousel-next')?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % totalItems;
    showItem(currentIndex);
  });

  // Auto cycle every 6 seconds
  setInterval(() => {
    if (totalItems > 1) {
      currentIndex = (currentIndex + 1) % totalItems;
      showItem(currentIndex);
    }
  }, 6000);
</script>
