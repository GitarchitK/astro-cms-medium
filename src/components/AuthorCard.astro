---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  role?: string;
  bio?: string;
  avatar?: string;
  twitter?: string;
  linkedin?: string;
}

const authorMetadata: Record<string, { role: string; bio: string; twitter?: string; linkedin?: string }> = {
  'Mahi': {
    role: 'Senior SEO Strategist & Content Lead',
    bio: 'Mahi is an expert in search engine visibility, keyword research, and on-page optimization. She reviews editorial layouts to align topics with user queries.',
    twitter: '#',
    linkedin: '#'
  },
  'Archit': {
    role: 'Lead Fullstack Architect & Founder',
    bio: 'Archit is a software engineer specializing in modern web frameworks, cloud deployments, and serverless pipelines. He drafts web guides and blueprints.',
    twitter: '#',
    linkedin: '#'
  },
  'Tiyasha': {
    role: 'Digital Productivity & UX Analyst',
    bio: 'Tiyasha is a workflow analyst focusing on remote productivity tools, SaaS automations, and workplace pipelines. She tests products to isolate scaling bottlenecks.',
    twitter: '#',
    linkedin: '#'
  },
  'Alisa': {
    role: 'SaaS Product Analyst',
    bio: 'Alisa tracks software-as-a-service platforms, creator monetization tools, and cloud integrations. She writes hands-on reviews and benchmark comparisons.',
    twitter: '#',
    linkedin: '#'
  }
};

const { name } = Astro.props;
const authorMeta = authorMetadata[name] || {};

const role = Astro.props.role || authorMeta.role || 'Expert Reviewer';
const bio = Astro.props.bio || authorMeta.bio || 'Experienced technology analyst and SaaS strategist covering online business growth and tool scaling guides.';
const avatar = Astro.props.avatar || '';
const twitter = Astro.props.twitter || authorMeta.twitter || '#';
const linkedin = Astro.props.linkedin || authorMeta.linkedin || '#';

// Initials fallback
const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
---

<div class="bg-slate-50 dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/80 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row gap-5 items-center md:items-start text-center md:text-left mt-12 shadow-sm font-sans">
  {avatar ? (
    <Image src={avatar} alt={name} width={64} height={64} class="w-16 h-16 rounded-2xl object-cover border-2 border-white dark:border-slate-800 shadow-md flex-shrink-0" />
  ) : (
    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-600 flex items-center justify-center text-white font-black text-xl shadow-md flex-shrink-0">
      {initials}
    </div>
  )}
  
  <div class="flex-1 space-y-2">
    <div>
      <span class="text-[10px] uppercase font-extrabold tracking-wider text-slate-400 dark:text-slate-500">Written By</span>
      <h4 class="text-lg font-black text-slate-900 dark:text-white leading-snug">{name}</h4>
      <p class="text-xs font-bold text-indigo-600 dark:text-indigo-400 mt-0.5">{role}</p>
    </div>
    <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed max-w-xl">
      {bio}
    </p>
    
    <!-- Social handles -->
    <div class="flex gap-3 justify-center md:justify-start pt-2">
      <a href={twitter} class="text-slate-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 text-xs font-bold flex items-center gap-1 transition-colors">
        Twitter
      </a>
      <span class="text-slate-200 dark:text-slate-800">|</span>
      <a href={linkedin} class="text-slate-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 text-xs font-bold flex items-center gap-1 transition-colors">
        LinkedIn
      </a>
    </div>
  </div>
</div>
