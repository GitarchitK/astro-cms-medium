---
export const prerender = false;
import '../../styles/global.css';

const session = Astro.cookies.get('admin_session');
if (session?.value === 'authenticated') return Astro.redirect('/admin/dashboard');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Log In ‹ Mershal — WordPress CMS</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background-color: #f0f0f1;
    }
    .font-outfit {
      font-family: 'Outfit', sans-serif;
    }
  </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-4 antialiased relative">

  <!-- Glow effect -->
  <div class="absolute top-[20%] left-[20%] w-[350px] h-[350px] rounded-full bg-blue-500/5 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-[20%] right-[20%] w-[350px] h-[350px] rounded-full bg-indigo-500/5 blur-[100px] pointer-events-none"></div>

  <div class="w-full max-w-[360px] relative z-10">
    
    <!-- WordPress logo container -->
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#1d2327] text-white font-outfit font-black text-4xl shadow-md border border-[#2c3338] select-none tracking-tighter">
        W
      </div>
      <h1 class="text-2xl font-black font-outfit tracking-wider text-slate-800 mt-3 bg-gradient-to-r from-blue-700 to-indigo-700 bg-clip-text text-transparent">Mershal CMS</h1>
    </div>

    <!-- Alert / Error container -->
    <div id="error" class="hidden mb-4 p-4 bg-white border-l-4 border-red-500 shadow-sm text-slate-700 text-xs leading-relaxed rounded-r-md"></div>

    <!-- Login Form Card -->
    <div class="bg-white rounded-md border border-[#c3c4c7] p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-600 mb-1.5 font-outfit">Email Address</label>
          <input
            type="email"
            id="email"
            class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/40 transition-all font-outfit"
            required
            autofocus
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-600 mb-1.5 font-outfit">Password</label>
          <input
            type="password"
            id="password"
            class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/40 transition-all font-outfit"
            required
          />
        </div>
        
        <div class="flex items-center justify-between pt-1">
          <label class="flex items-center gap-1.5 text-xs text-slate-500 cursor-pointer select-none">
            <input type="checkbox" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500 w-3.5 h-3.5" />
            <span>Remember Me</span>
          </label>
          
          <button
            type="submit"
            id="submit-btn"
            class="bg-[#2271b1] hover:bg-[#135e96] border border-[#2271b1] hover:border-[#135e96] shadow-sm text-white font-bold px-4 py-2 rounded text-xs transition-all active:scale-[0.98] cursor-pointer"
          >
            Log In
          </button>
        </div>
      </form>
    </div>

    <!-- Help links -->
    <div class="mt-6 flex justify-between px-1 text-xs text-slate-500">
      <a href="/" class="hover:text-blue-600 transition-colors">← Go to Mershal</a>
      <a href="#" class="hover:text-blue-600 transition-colors">Lost your password?</a>
    </div>

  </div>

  <script>
    import { auth } from '../../lib/firebase';
    import { signInWithEmailAndPassword } from 'firebase/auth';

    const loginForm = document.getElementById('login-form') as HTMLFormElement;

    loginForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const errorEl = document.getElementById('error') as HTMLDivElement;
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;

      btn.textContent = 'Logging in...';
      btn.disabled = true;
      errorEl.classList.add('hidden');

      try {
        // 1. Authenticate with Firebase Client Auth SDK
        const userCredential = await signInWithEmailAndPassword(auth, email, password);
        const user = userCredential.user;

        // 2. Fetch User ID Token
        const idToken = await user.getIdToken();

        // 3. Verify on server and create HTTP-Only session cookie
        const res = await fetch('/api/admin/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken }),
        });

        if (res.ok) {
          window.location.href = '/admin/dashboard';
        } else {
          const data = await res.json();
          throw new Error(data.error || 'Server session creation failed');
        }
      } catch (err: any) {
        console.error('Authentication Error:', err);
        errorEl.innerHTML = `<strong>Error</strong>: ${err.message || 'Authentication failed. Please verify credentials.'}`;
        errorEl.classList.remove('hidden');
        btn.textContent = 'Log In';
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
