---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
---

<AdminLayout title="Posts Management" activeNav="posts">
  
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-black font-outfit text-slate-800 tracking-tight flex items-center gap-2">
        Posts
        <a href="/admin/posts/new" class="bg-white hover:bg-slate-50 border border-[#8c8f94] hover:border-blue-600 text-blue-600 text-xs px-2.5 py-1 rounded transition-colors select-none font-bold font-outfit">Add New</a>
      </h1>
      <p class="text-slate-500 text-xs mt-0.5 font-outfit font-medium">Manage, edit, filter, and schedule your publication articles</p>
    </div>
  </div>

  <!-- Alert Container -->
  <div id="posts-alert" class="hidden mb-4 p-4 rounded text-xs font-semibold font-outfit border animate-in fade-in duration-200"></div>

  <!-- Status Tabs -->
  <div class="flex border-b border-[#c3c4c7] text-xs font-outfit mb-4 overflow-x-auto whitespace-nowrap bg-white border rounded shadow-sm">
    <button type="button" id="tab-all" class="px-4 py-3 border-b-2 border-blue-600 text-blue-600 font-bold focus:outline-none cursor-pointer">
      All <span class="text-slate-400 font-normal" id="tab-count-all">(0)</span>
    </button>
    <button type="button" id="tab-published" class="px-4 py-3 border-b-2 border-transparent text-slate-600 hover:text-blue-600 font-medium focus:outline-none cursor-pointer">
      Published <span class="text-slate-400 font-normal" id="tab-count-published">(0)</span>
    </button>
    <button type="button" id="tab-scheduled" class="px-4 py-3 border-b-2 border-transparent text-slate-600 hover:text-blue-600 font-medium focus:outline-none cursor-pointer">
      Scheduled <span class="text-slate-400 font-normal" id="tab-count-scheduled">(0)</span>
    </button>
    <button type="button" id="tab-draft" class="px-4 py-3 border-b-2 border-transparent text-slate-600 hover:text-blue-600 font-medium focus:outline-none cursor-pointer">
      Drafts <span class="text-slate-400 font-normal" id="tab-count-draft">(0)</span>
    </button>
  </div>

  <!-- Filter and Search Bar -->
  <div class="bg-white border border-[#c3c4c7] p-3 rounded shadow-sm mb-4 flex flex-col md:flex-row md:items-center justify-between gap-3 text-xs font-outfit">
    <!-- Filters on left -->
    <div class="flex flex-wrap items-center gap-2">
      <!-- Bulk Actions -->
      <select id="bulk-action" class="bg-white border border-[#8c8f94] text-slate-700 rounded px-2.5 py-1.5 focus:outline-none focus:border-blue-500 cursor-pointer">
        <option value="">Bulk Actions</option>
        <option value="delete">Move to Trash</option>
      </select>
      <button id="apply-bulk" class="bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 font-bold px-3 py-1.5 rounded transition-all active:scale-[0.98] cursor-pointer">
        Apply
      </button>

      <div class="h-6 w-px bg-slate-200 hidden sm:block"></div>

      <!-- Dates Dropdown -->
      <select id="filter-date" class="bg-white border border-[#8c8f94] text-slate-700 rounded px-2.5 py-1.5 focus:outline-none focus:border-blue-500 cursor-pointer">
        <option value="">All Dates</option>
      </select>

      <!-- Categories Dropdown -->
      <select id="filter-category" class="bg-white border border-[#8c8f94] text-slate-700 rounded px-2.5 py-1.5 focus:outline-none focus:border-blue-500 cursor-pointer">
        <option value="">All Categories</option>
      </select>

      <button id="apply-filter" class="bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 font-bold px-3 py-1.5 rounded transition-all active:scale-[0.98] cursor-pointer">
        Filter
      </button>
    </div>

    <!-- Search on right -->
    <div class="relative w-full md:w-64">
      <input type="text" id="search-input" placeholder="Search Posts..." class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded pl-3 pr-8 py-1.5 focus:outline-none focus:border-blue-500 placeholder-slate-400 font-outfit" />
      <svg class="w-4 h-4 text-slate-400 absolute right-2.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </div>
  </div>

  <!-- Posts Table -->
  <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-xs font-outfit">
        <thead>
          <tr class="bg-slate-50 border-b border-[#c3c4c7] text-[#50575e] uppercase tracking-wide font-bold select-none">
            <th class="px-4 py-3 w-10 text-center">
              <input type="checkbox" id="select-all-posts" class="rounded border-slate-350 text-blue-600 focus:ring-blue-500 w-3.5 h-3.5 cursor-pointer" />
            </th>
            <th class="px-4 py-3 font-bold">Title</th>
            <th class="px-4 py-3 font-bold w-32">Author</th>
            <th class="px-4 py-3 font-bold w-40">Categories</th>
            <th class="px-4 py-3 font-bold w-24 text-center">Words</th>
            <th class="px-4 py-3 font-bold w-44">Date</th>
          </tr>
        </thead>
        <tbody id="posts-table-body" class="divide-y divide-slate-100">
          <tr>
            <td colspan="6" class="px-4 py-16 text-center text-slate-400 font-medium">
              <div class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4 animate-spin text-blue-600" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                <span>Loading articles...</span>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    let allPosts: any[] = [];
    let categories: any[] = [];
    let currentStatusFilter = 'all'; // all, published, scheduled, draft
    let isDeleting = false;
    let siteUrl = 'https://mershal.in';
    const isIndexing: Record<string, boolean> = {};

    // Load Settings to obtain the configured domain URL
    async function loadSettings() {
      try {
        const res = await fetch('/api/admin/settings');
        if (res.ok) {
          const settings = await res.json();
          siteUrl = (settings.siteUrl || 'https://mershal.in').replace(/\/$/, '');
        }
      } catch (err) {
        console.error('Failed to load settings site URL:', err);
      }
    }

    // Load Categories from API for Filter dropdown
    async function loadCategories() {
      try {
        const res = await fetch('/api/admin/categories');
        if (res.ok) {
          categories = await res.json();
          const filterDropdown = document.getElementById('filter-category') as HTMLSelectElement;
          if (filterDropdown) {
            filterDropdown.innerHTML = '<option value="">All Categories</option>' + 
              categories.map(c => `<option value="${c.name}">${c.name}</option>`).join('');
          }
        }
      } catch (err) {
        console.error('Failed to load categories for filtering:', err);
      }
    }

    // Load Posts list
    async function loadPosts() {
      try {
        const res = await fetch('/api/admin/posts');
        if (res.ok) {
          allPosts = await res.json();
          buildDateFilter();
          updateTabCounts();
          applyFiltersAndRender();
        } else {
          throw new Error('Failed to fetch posts');
        }
      } catch (err) {
        console.error('Error loading posts:', err);
        const tbody = document.getElementById('posts-table-body')!;
        tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-red-650 font-bold">Failed to load articles. Please refresh the page.</td></tr>`;
      }
    }

    // Populate the dates dropdown with Month Year options dynamically based on post list
    function buildDateFilter() {
      const dropdown = document.getElementById('filter-date') as HTMLSelectElement;
      if (!dropdown) return;

      const dates = allPosts
        .map(p => p.publishedAt ? new Date(p.publishedAt) : null)
        .filter((d): d is Date => d !== null);

      // Extract unique Month Year strings
      const monthYears = Array.from(new Set(dates.map(d => {
        return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
      })));

      dropdown.innerHTML = '<option value="">All Dates</option>' +
        monthYears.map(my => `<option value="${my}">${my}</option>`).join('');
    }

    // Update the tab counts
    function updateTabCounts() {
      const now = new Date();
      let published = 0;
      let scheduled = 0;
      let drafts = 0;

      allPosts.forEach(p => {
        if (p.status === 'draft') {
          drafts++;
        } else {
          const pubDate = p.publishedAt ? new Date(p.publishedAt) : null;
          if (pubDate && pubDate > now) {
            scheduled++;
          } else {
            published++;
          }
        }
      });

      document.getElementById('tab-count-all')!.textContent = `(${allPosts.length})`;
      document.getElementById('tab-count-published')!.textContent = `(${published})`;
      document.getElementById('tab-count-scheduled')!.textContent = `(${scheduled})`;
      document.getElementById('tab-count-draft')!.textContent = `(${drafts})`;
    }

    // Set tab active state styles
    function setTabActive(tabId: string) {
      const tabs = ['tab-all', 'tab-published', 'tab-scheduled', 'tab-draft'];
      tabs.forEach(id => {
        const el = document.getElementById(id)!;
        if (id === tabId) {
          el.className = 'px-4 py-3 border-b-2 border-blue-600 text-blue-600 font-bold focus:outline-none cursor-pointer';
        } else {
          el.className = 'px-4 py-3 border-b-2 border-transparent text-slate-600 hover:text-blue-600 font-medium focus:outline-none cursor-pointer';
        }
      });
    }

    // Main filtering logic
    function applyFiltersAndRender() {
      const search = (document.getElementById('search-input') as HTMLInputElement).value.toLowerCase();
      const dateVal = (document.getElementById('filter-date') as HTMLSelectElement).value;
      const categoryVal = (document.getElementById('filter-category') as HTMLSelectElement).value;
      const now = new Date();

      const filtered = allPosts.filter(p => {
        // Status Filter
        let matchesStatus = true;
        if (currentStatusFilter === 'published') {
          const pubDate = p.publishedAt ? new Date(p.publishedAt) : null;
          matchesStatus = p.status === 'published' && (!pubDate || pubDate <= now);
        } else if (currentStatusFilter === 'scheduled') {
          const pubDate = p.publishedAt ? new Date(p.publishedAt) : null;
          matchesStatus = p.status === 'published' && pubDate !== null && pubDate > now;
        } else if (currentStatusFilter === 'draft') {
          matchesStatus = p.status === 'draft';
        }

        // Search Filter
        const matchesSearch = !search ||
          p.title.toLowerCase().includes(search) ||
          (p.slug && p.slug.toLowerCase().includes(search));

        // Date Filter
        let matchesDate = true;
        if (dateVal && p.publishedAt) {
          const pubDate = new Date(p.publishedAt);
          const monthYearStr = pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
          matchesDate = monthYearStr === dateVal;
        }

        // Category Filter
        const matchesCategory = !categoryVal || p.category === categoryVal;

        return matchesStatus && matchesSearch && matchesDate && matchesCategory;
      });

      renderPosts(filtered);
    }

    // Render posts to the table DOM
    function renderPosts(posts: any[]) {
      const tbody = document.getElementById('posts-table-body')!;
      if (!posts.length) {
        tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-12 text-center text-slate-450 font-medium">No posts found matching the filters.</td></tr>`;
        return;
      }

      const now = new Date();
      tbody.innerHTML = posts.map(p => {
        let statusBadge = '';
        let dateLabel = 'Published';
        if (p.status === 'draft') {
          statusBadge = '<span class="text-slate-450 border border-slate-200 px-1.5 py-0.5 rounded font-bold uppercase tracking-wider text-[9px] bg-slate-50 select-none ml-1.5">Draft</span>';
          dateLabel = 'Last Modified';
        } else {
          const pubDate = p.publishedAt ? new Date(p.publishedAt) : null;
          if (pubDate && pubDate > now) {
            statusBadge = '<span class="text-indigo-650 border border-indigo-200 px-1.5 py-0.5 rounded font-bold uppercase tracking-wider text-[9px] bg-indigo-50 select-none ml-1.5">Scheduled</span>';
            dateLabel = 'Scheduled';
          }
        }

        const pubDateFormatted = p.publishedAt
          ? new Date(p.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })
          : '—';

        const catSlug = (p.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-');

        // Create standard row + quick-edit drawer placeholder (hidden by default)
        return `
          <tr id="row-${p.id}" class="group hover:bg-[#f6f7f7] transition-colors relative">
            <td class="px-4 py-4 text-center">
              <input type="checkbox" name="post-select" value="${p.id}" class="rounded border-slate-350 text-blue-600 focus:ring-blue-500 w-3.5 h-3.5 cursor-pointer" />
            </td>
            <td class="px-4 py-4 min-w-[200px]">
              <div class="flex items-center flex-wrap gap-2">
                <a href="/admin/posts/edit?id=${p.id}" class="font-bold text-[#2271b1] hover:text-[#135e96] text-sm break-all line-clamp-1">${p.title}</a>
                ${statusBadge}
                ${p.status === 'published' ? `
                  <button id="idx-btn-${p.id}" onclick="window.indexPost('${p.id}', '${catSlug}', '${p.slug}')" class="px-1.5 py-0.5 rounded bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 text-emerald-700 text-[9px] font-bold uppercase tracking-wider transition-all cursor-pointer inline-flex items-center gap-0.5 select-none" title="Request instant Google search indexing for this published post">
                    <svg class="w-2.5 h-2.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18.2"/></svg>
                    Index
                  </button>
                ` : ''}
              </div>
              
              <!-- Hover Action Links (WordPress style) -->
              <div class="flex items-center gap-2 text-[10px] font-semibold text-[#50575e] mt-1.5 opacity-0 group-hover:opacity-100 transition-opacity flex-wrap select-none">
                <a href="/admin/posts/edit?id=${p.id}" class="text-[#2271b1] hover:text-[#135e96]">Edit</a>
                <span class="text-slate-300">|</span>
                <button onclick="window.openQuickEdit('${p.id}')" class="text-[#2271b1] hover:text-[#135e96] cursor-pointer focus:outline-none">Quick Edit</button>
                <span class="text-slate-300">|</span>
                <button onclick="window.trashPost('${p.id}')" class="text-red-650 hover:text-red-800 cursor-pointer focus:outline-none">Trash</button>
                <span class="text-slate-300">|</span>
                <a href="/${catSlug}/${p.slug}" target="_blank" class="text-[#2271b1] hover:text-[#135e96]">View</a>
              </div>
            </td>
            <td class="px-4 py-4 text-slate-550 font-medium">${p.author || 'Editor'}</td>
            <td class="px-4 py-4 text-slate-550 font-medium">
              <span class="inline-flex px-1.5 py-0.5 rounded bg-slate-50 border border-slate-200">${p.category || 'Uncategorized'}</span>
            </td>
            <td class="px-4 py-4 text-center font-mono font-semibold text-slate-450">${p.wordCount || 0}</td>
            <td class="px-4 py-4 text-slate-400">
              <span class="font-medium text-slate-600 block">${dateLabel}</span>
              <span class="text-[10px] font-semibold font-mono block mt-0.5">${pubDateFormatted}</span>
            </td>
          </tr>
          
          <!-- Inline Quick Edit Drawer -->
          <tr id="quick-edit-${p.id}" class="hidden bg-[#f0f6fa] border-y border-[#c3c4c7] shadow-inner">
            <td colspan="6" class="px-6 py-4">
              <div class="space-y-4">
                <h4 class="text-xs font-bold text-slate-700 uppercase tracking-widest font-outfit">Quick Edit</h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <!-- Col 1 -->
                  <div class="space-y-3">
                    <div>
                      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Title</label>
                      <input type="text" id="qe-title-${p.id}" value="${p.title}" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 font-outfit" />
                    </div>
                    <div>
                      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Slug</label>
                      <input type="text" id="qe-slug-${p.id}" value="${p.slug || ''}" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 font-mono" />
                    </div>
                  </div>

                  <!-- Col 2 -->
                  <div class="space-y-3">
                    <div>
                      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Date & Time</label>
                      <input type="datetime-local" id="qe-date-${p.id}" value="${p.publishedAt ? p.publishedAt.substring(0, 16) : ''}" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 font-mono" />
                    </div>
                    <div>
                      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Author</label>
                      <input type="text" id="qe-author-${p.id}" value="${p.author || 'Editorial Team'}" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 font-outfit" />
                    </div>
                  </div>

                  <!-- Col 3 -->
                  <div class="space-y-3">
                    <div>
                      <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Category</label>
                      <select id="qe-category-${p.id}" class="w-full bg-white border border-[#8c8f94] text-slate-700 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 cursor-pointer">
                        ${categories.map(c => `<option value="${c.name}" ${c.name === p.category ? 'selected' : ''}>${c.name}</option>`).join('')}
                      </select>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                      <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Status</label>
                        <select id="qe-status-${p.id}" class="w-full bg-white border border-[#8c8f94] text-slate-700 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 cursor-pointer">
                          <option value="published" ${p.status === 'published' ? 'selected' : ''}>Published</option>
                          <option value="draft" ${p.status === 'draft' ? 'selected' : ''}>Draft</option>
                        </select>
                      </div>
                      <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Tags</label>
                        <input type="text" id="qe-tags-${p.id}" value="${(p.tags || []).join(', ')}" placeholder="ai, blogging" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-blue-500 font-outfit" />
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Footer buttons -->
                <div class="flex items-center justify-between border-t border-slate-200/80 pt-3">
                  <div id="qe-error-${p.id}" class="text-red-650 font-bold text-[11px] hidden"></div>
                  <div class="flex items-center gap-2 ml-auto">
                    <button onclick="window.closeQuickEdit('${p.id}')" class="bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 font-bold px-3 py-1.5 rounded transition-all active:scale-[0.98] cursor-pointer">Cancel</button>
                    <button id="qe-save-btn-${p.id}" onclick="window.saveQuickEdit('${p.id}')" class="bg-blue-600 hover:bg-blue-700 border border-blue-600 text-white font-bold px-4 py-1.5 rounded transition-all active:scale-[0.98] cursor-pointer">Update</button>
                  </div>
                </div>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    // Set up tab buttons click listeners
    const tabMapping = {
      'tab-all': 'all',
      'tab-published': 'published',
      'tab-scheduled': 'scheduled',
      'tab-draft': 'draft'
    };

    Object.entries(tabMapping).forEach(([tabId, filterValue]) => {
      document.getElementById(tabId)!.addEventListener('click', () => {
        currentStatusFilter = filterValue;
        setTabActive(tabId);
        applyFiltersAndRender();
      });
    });

    // Apply Filter button handler
    document.getElementById('apply-filter')?.addEventListener('click', () => {
      applyFiltersAndRender();
    });

    // Live search input handler
    document.getElementById('search-input')?.addEventListener('input', () => {
      applyFiltersAndRender();
    });

    // Header Select All Checkbox Handler
    document.getElementById('select-all-posts')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      const checkboxes = document.querySelectorAll('input[name="post-select"]') as NodeListOf<HTMLInputElement>;
      checkboxes.forEach(cb => cb.checked = checked);
    });

    // Bulk actions apply handler
    document.getElementById('apply-bulk')?.addEventListener('click', async () => {
      const action = (document.getElementById('bulk-action') as HTMLSelectElement).value;
      if (!action) return;

      const checkedBoxes = Array.from(document.querySelectorAll('input[name="post-select"]:checked')) as HTMLInputElement[];
      if (!checkedBoxes.length) {
        showGlobalAlert('No posts selected.', 'error');
        return;
      }

      if (action === 'delete') {
        if (!confirm(`Are you sure you want to delete ${checkedBoxes.length} selected post(s)?`)) return;
        
        let successCount = 0;
        let failCount = 0;

        for (const cb of checkedBoxes) {
          const id = cb.value;
          try {
            const res = await fetch(`/api/admin/posts?id=${id}`, { method: 'DELETE' });
            if (res.ok) successCount++;
            else failCount++;
          } catch {
            failCount++;
          }
        }

        showGlobalAlert(`Successfully trashed ${successCount} post(s). ${failCount > 0 ? `Failed to trash ${failCount} post(s).` : ''}`, 'success');
        
        // Reset check all
        (document.getElementById('select-all-posts') as HTMLInputElement).checked = false;
        
        // Reload posts
        loadPosts();
      }
    });

    // Alert helper
    function showGlobalAlert(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('posts-alert')!;
      el.textContent = msg;
      el.className = `mb-4 p-4 rounded text-xs font-semibold font-outfit border animate-in fade-in duration-200 ${type === 'success' ? 'bg-emerald-50 text-emerald-700 border-emerald-250' : 'bg-red-50 text-red-700 border-red-200'}`;
      el.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Add handlers to the global window object for in-table inline event listeners
    (window as any).trashPost = async function(id: string) {
      if (isDeleting) return;
      
      const row = document.getElementById(`row-${id}`);
      const titleLink = row?.querySelector('a');
      const title = titleLink ? titleLink.textContent : 'this post';

      if (!confirm(`Are you sure you want to delete "${title}"?\nThis action cannot be undone.`)) return;

      isDeleting = true;
      try {
        const res = await fetch(`/api/admin/posts?id=${id}`, { method: 'DELETE' });
        if (res.ok) {
          showGlobalAlert(`Successfully moved "${title}" to Trash.`, 'success');
          loadPosts();
        } else {
          showGlobalAlert('Failed to delete post. Please try again.', 'error');
        }
      } catch (err) {
        console.error('Delete post error:', err);
        showGlobalAlert('An error occurred while deleting the post.', 'error');
      } finally {
        isDeleting = false;
      }
    };

    (window as any).openQuickEdit = function(id: string) {
      // Hide standard row, show quick edit row
      document.getElementById(`row-${id}`)!.classList.add('hidden');
      
      const qeRow = document.getElementById(`quick-edit-${id}`)!;
      qeRow.classList.remove('hidden');
      
      // Auto focus title input
      const titleInput = document.getElementById(`qe-title-${id}`) as HTMLInputElement;
      titleInput?.focus();
    };

    (window as any).closeQuickEdit = function(id: string) {
      // Hide quick edit row, show standard row
      document.getElementById(`quick-edit-${id}`)!.classList.add('hidden');
      document.getElementById(`row-${id}`)!.classList.remove('hidden');
    };

    (window as any).saveQuickEdit = async function(id: string) {
      const title = (document.getElementById(`qe-title-${id}`) as HTMLInputElement).value.trim();
      const slug = (document.getElementById(`qe-slug-${id}`) as HTMLInputElement).value.trim();
      const dateVal = (document.getElementById(`qe-date-${id}`) as HTMLInputElement).value;
      const category = (document.getElementById(`qe-category-${id}`) as HTMLSelectElement).value;
      const status = (document.getElementById(`qe-status-${id}`) as HTMLSelectElement).value;
      const author = (document.getElementById(`qe-author-${id}`) as HTMLInputElement).value.trim();
      const tags = (document.getElementById(`qe-tags-${id}`) as HTMLInputElement).value.split(',').map(t => t.trim()).filter(Boolean);

      const errEl = document.getElementById(`qe-error-${id}`)!;
      const saveBtn = document.getElementById(`qe-save-btn-${id}`) as HTMLButtonElement;

      if (!title) {
        errEl.textContent = 'Title is required';
        errEl.classList.remove('hidden');
        return;
      }

      saveBtn.disabled = true;
      saveBtn.textContent = 'Updating...';
      errEl.classList.add('hidden');

      try {
        // 1. Fetch full details from database first to prevent overwriting content or excerpt
        const rDetails = await fetch(`/api/admin/posts?id=${id}`);
        if (!rDetails.ok) throw new Error('Failed to retrieve full article content');
        const details = await rDetails.json();

        // 2. Merge changes
        const payload = {
          ...details, // keep all original fields (content, excerpt, custom CSS, FAQ items, isCustomHtml)
          id,
          title,
          slug,
          publishDate: dateVal ? new Date(dateVal).toISOString() : details.publishDate,
          category,
          status,
          author,
          tags
        };

        // 3. Send update
        const rUpdate = await fetch('/api/admin/posts', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const updateData = await rUpdate.json();
        if (!rUpdate.ok) throw new Error(updateData.error || 'Failed to update article');

        // Close drawer and reload list
        (window as any).closeQuickEdit(id);
        showGlobalAlert(`Post "${title}" updated successfully.`, 'success');
        loadPosts();
      } catch (err: any) {
        console.error('Quick edit save failed:', err);
        errEl.textContent = err.message || 'Failed to save changes';
        errEl.classList.remove('hidden');
        saveBtn.disabled = false;
        saveBtn.textContent = 'Update';
      }
    };

    // Global index post helper
    (window as any).indexPost = async function(id: string, catSlug: string, slug: string) {
      if (isIndexing[id]) return;

      const btn = document.getElementById(`idx-btn-${id}`) as HTMLButtonElement;
      if (!btn) return;
      
      const originalHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = `<svg class="w-2.5 h-2.5 animate-spin shrink-0" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
      isIndexing[id] = true;

      const fullUrl = `${siteUrl}/${catSlug}/${slug}`;

      try {
        const res = await fetch('/api/admin/indexing', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: fullUrl, action: 'publish' })
        });

        const data = await res.json();
        if (res.ok) {
          showGlobalAlert(`Successfully requested Google Search indexing for "${fullUrl}".`, 'success');
        } else {
          throw new Error(data.error || 'API response failed');
        }
      } catch (err: any) {
        console.error('Manual URL indexing failed from table:', err);
        showGlobalAlert(`Failed to index "${fullUrl}": ${err.message || 'API error'}. Verify credential/owner permissions in Tools > Google Auto-Indexing.`, 'error');
      } finally {
        isIndexing[id] = false;
        btn.disabled = false;
        btn.innerHTML = originalHtml;
      }
    };

    // Load initial data
    loadSettings().then(() => {
      loadCategories().then(loadPosts);
    });
  </script>
</AdminLayout>
