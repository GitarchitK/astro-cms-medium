---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
const postId = Astro.url.searchParams.get('id');
if (!postId) return Astro.redirect('/admin/posts');
---

<AdminLayout title="Edit Post" activeNav="posts">
  
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-black font-outfit text-slate-800 tracking-tight flex items-center gap-2">
        Edit Post
        <a id="view-article-btn" href="#" target="_blank" class="hidden bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 text-xs px-2.5 py-1 rounded transition-colors select-none font-bold font-outfit">Preview / View Post</a>
      </h1>
      <p class="text-slate-500 text-xs mt-0.5 font-outfit font-medium font-outfit" id="header-slug">Modify post contents and publication specifications</p>
    </div>
  </div>

  <div id="alert" class="hidden mb-5 p-4 rounded text-xs font-semibold font-outfit border animate-in fade-in duration-200"></div>

  <!-- Loading State Spinner -->
  <div id="loading-state" class="bg-white border border-[#c3c4c7] rounded p-12 text-center shadow-sm">
    <div class="inline-flex items-center justify-center gap-2 text-slate-500 font-medium">
      <svg class="w-5 h-5 animate-spin text-blue-600" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
      <span>Retrieving article details...</span>
    </div>
  </div>

  <!-- Gutenberg-style Split Grid Layout (Hidden until loaded) -->
  <form id="editor-form" class="hidden grid-cols-1 lg:grid-cols-4 gap-6 font-outfit text-xs" data-post-id={postId}>
    
    <!-- Left Column: Content Core (Spans 3 cols) -->
    <div class="lg:col-span-3 space-y-6">
      
      <!-- Title input (WP-style borderless & large) -->
      <div class="bg-white border border-[#c3c4c7] p-4 rounded shadow-sm">
        <input 
          id="title" 
          type="text" 
          placeholder="Add title" 
          class="w-full bg-transparent border-b border-transparent hover:border-slate-200 focus:border-blue-500 text-slate-800 text-xl font-bold px-1 py-2 focus:outline-none transition-colors"
          required
        />
        <!-- Permalink/Slug editor -->
        <div class="flex items-center gap-1.5 text-slate-550 mt-2 font-mono text-[10px] pl-1 select-none">
          <strong class="text-slate-400 font-bold uppercase tracking-wider text-[8px]">Permalink:</strong>
          <span id="permalink-prefix">https://mershal.in/category/</span>
          <span id="permalink-slug" class="bg-yellow-50 px-1 py-0.5 border border-yellow-200 rounded font-semibold text-slate-755">slug-name</span>
          <button type="button" id="edit-slug-btn" class="text-blue-600 hover:text-blue-800 hover:underline cursor-pointer focus:outline-none font-bold">Edit</button>
          
          <!-- Inline Slug Edit Container -->
          <div id="slug-edit-container" class="hidden items-center gap-1">
            <input type="text" id="slug-input" class="bg-white border border-slate-350 px-1.5 py-0.5 text-[10px] font-mono rounded w-36 focus:outline-none" />
            <button type="button" id="save-slug-btn" class="bg-[#2271b1] hover:bg-[#135e96] text-white px-2 py-0.5 rounded font-bold">Ok</button>
            <button type="button" id="cancel-slug-btn" class="text-slate-500 hover:text-slate-700">Cancel</button>
          </div>
        </div>
      </div>

      <!-- Editor Section -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        
        <!-- Editor Switcher Tabs & Tools -->
        <div class="bg-slate-50 border-b border-slate-200 px-4 py-2 flex flex-wrap gap-3 items-center justify-between">
          <div class="flex items-center gap-1 bg-[#f0f0f1] border border-slate-250 p-0.5 rounded">
            <button type="button" id="btn-view-compose" class="px-3 py-1 rounded bg-white border border-slate-200 text-slate-800 font-bold tracking-wide transition cursor-pointer shadow-sm">Visual</button>
            <button type="button" id="btn-view-html" class="px-3 py-1 rounded hover:bg-slate-50 text-slate-550 hover:text-slate-800 font-semibold tracking-wide transition cursor-pointer">Text (HTML)</button>
          </div>
          <div class="flex items-center gap-3">
            <span id="word-count" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">0 words</span>
          </div>
        </div>

        <!-- Rich Text Toolbar (Shown only in Visual Mode) -->
        <div id="visual-toolbar" class="bg-slate-50/50 border-b border-slate-200 px-4 py-2.5 flex flex-wrap gap-1.5 items-center">
          <div class="flex items-center gap-1 bg-white border border-slate-200 p-1 rounded">
            <button type="button" id="btn-bold" class="p-1.5 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Bold"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 5.25h6.75a3 3 0 013 3v0a3 3 0 01-3 3H6.75v-6zm0 6h7.5a3.375 3.375 0 013.375 3.375v0a3.375 3.375 0 01-3.375 3.375H6.75v-6.75z"/></svg></button>
            <button type="button" id="btn-italic" class="p-1.5 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Italic"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 4.5h-7.5m7.5 0v3m0-3L12 19.5m0 0H4.5m7.5 0v-3"/></svg></button>
            <button type="button" id="btn-underline" class="p-1.5 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Underline"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 3.75V11.25a5.25 5.25 0 11-10.5 0V3.75m0 16.5h10.5"/></svg></button>
          </div>
          
          <div class="flex items-center gap-1 bg-white border border-slate-200 p-1 rounded">
            <button type="button" id="btn-h2" class="px-2 py-1 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 font-bold text-[10px] transition cursor-pointer" title="Heading 2">H2</button>
            <button type="button" id="btn-h3" class="px-2 py-1 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 font-bold text-[10px] transition cursor-pointer" title="Heading 3">H3</button>
            <button type="button" id="btn-p" class="px-2 py-1 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 font-bold text-[10px] transition cursor-pointer" title="Paragraph">P</button>
          </div>

          <div class="flex items-center gap-1 bg-white border border-slate-200 p-1 rounded">
            <button type="button" id="btn-ul" class="p-1.5 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Bullet List"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
            <button type="button" id="btn-ol" class="p-1.5 rounded hover:bg-slate-100 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Numbered List"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
          </div>

          <div class="flex items-center gap-1 bg-white border border-slate-200 p-1 rounded">
            <button type="button" id="btn-link" class="p-1.5 rounded hover:bg-slate-105 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Add Link"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg></button>
            <button type="button" id="btn-insert-image" class="p-1.5 rounded hover:bg-slate-105 text-slate-600 hover:text-slate-900 transition cursor-pointer" title="Insert Image from Library"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></button>
          </div>

          <div class="flex items-center gap-1 bg-white border border-slate-200 p-1 rounded">
            <button type="button" id="btn-tip" class="px-2 py-1 rounded bg-emerald-50 hover:bg-emerald-100 text-emerald-700 text-[10px] font-bold transition border border-emerald-200/50" title="Insert Tip Box">💡 Tip</button>
            <button type="button" id="btn-warning" class="px-2 py-1 rounded bg-amber-50 hover:bg-amber-100 text-amber-700 text-[10px] font-bold transition border border-amber-200/50" title="Insert Warning Box">⚠️ Alert</button>
            <button type="button" id="btn-info" class="px-2 py-1 rounded bg-blue-50 hover:bg-blue-100 text-blue-700 text-[10px] font-bold transition border border-blue-200/50" title="Insert Info Box">ℹ️ Note</button>
          </div>
        </div>

        <!-- Editor Content Area -->
        <div id="wysiwyg-editor" class="px-5 py-4 bg-white text-slate-800 min-h-[450px] overflow-y-auto outline-none prose max-w-none"></div>
        <textarea id="raw-html-editor" class="hidden w-full min-h-[450px] font-mono bg-slate-900 text-slate-100 p-5 focus:outline-none resize-y text-xs leading-relaxed" placeholder="Write or paste your custom HTML tags here..."></textarea>
      </div>

      <!-- Excerpt Card -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Excerpt</h3>
        </div>
        <div class="p-4">
          <textarea id="excerpt" rows="2" placeholder="Write a short summary of this article..." class="w-full bg-white border border-slate-350 text-slate-800 rounded px-3 py-2 focus:outline-none focus:border-blue-500 font-outfit resize-none placeholder-slate-400"></textarea>
          <p class="text-[9px] text-slate-400 font-semibold uppercase tracking-wider mt-1.5">Excerpts are optional hand-crafted summaries of your content that can be used in your website layout feeds.</p>
        </div>
      </div>

      <!-- FAQ Accordion Builder Card -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
          <h3 class="text-xs font-bold text-slate-655 uppercase tracking-widest font-outfit">FAQ Accordion (Structured Schema)</h3>
          <button type="button" id="add-faq-item" class="bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 font-bold px-2 py-1 rounded transition-colors cursor-pointer select-none">Add Item</button>
        </div>
        <div class="p-4">
          <div id="faq-items-list" class="space-y-4">
            <!-- FAQ Rows dynamically loaded here -->
            <p id="faq-empty-state" class="text-slate-400 italic text-center py-4">No FAQs added yet. Click "Add Item" to supply structured schema questions.</p>
          </div>
        </div>
      </div>



    </div>

    <!-- Right Column: Sidebar Settings (1 col) -->
    <div class="space-y-6">
      
      <!-- Publish Widget -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Publish Settings</h3>
        </div>
        <div class="p-4 space-y-4 text-xs font-outfit">
          <div class="flex items-center justify-between">
            <span class="text-slate-500 font-medium">Status:</span>
            <select id="status" class="bg-white border border-[#8c8f94] text-slate-700 rounded px-2 py-1 focus:outline-none cursor-pointer">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
            </select>
          </div>
          
          <div class="space-y-1.5">
            <label class="block text-slate-500 font-medium">Publish Date & Time (Schedule)</label>
            <input id="publish-date" type="datetime-local" class="w-full bg-white border border-[#8c8f94] text-slate-700 rounded px-2 py-1.5 focus:outline-none font-mono cursor-pointer" />
            <p class="text-[9px] text-slate-400 font-semibold uppercase tracking-wider font-outfit">Update this value to reschedule the post.</p>
          </div>
        </div>
        
        <!-- Actions bottom bar -->
        <div class="px-4 py-3 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
          <button type="button" id="trash-post-btn" class="text-red-650 hover:text-red-800 font-bold hover:underline cursor-pointer focus:outline-none">Move to Trash</button>
          <button type="button" id="publish-btn" class="bg-[#2271b1] hover:bg-[#135e96] border border-[#2271b1] text-white font-bold px-4 py-1.5 rounded transition-all active:scale-[0.98] cursor-pointer font-semibold">Update</button>
        </div>
      </div>

      <!-- Layout Attribute Card -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-655 uppercase tracking-widest font-outfit">Post Attributes</h3>
        </div>
        <div class="p-4 space-y-3 font-outfit">
          <div class="flex items-center gap-2">
            <input id="is-custom-html" type="checkbox" class="w-3.5 h-3.5 text-blue-600 border-slate-350 rounded focus:ring-blue-500 cursor-pointer" />
            <label for="is-custom-html" class="font-bold text-slate-600 cursor-pointer select-none">Custom HTML Layout</label>
          </div>
          <p class="text-[9px] text-slate-400 font-semibold uppercase tracking-wider leading-relaxed">
            Allows writing direct HTML markup to compose the full page body inside standard blog wrappers.
          </p>
        </div>
      </div>

      <!-- Categories checklist widget (WP-Style) -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Categories</h3>
        </div>
        <div class="p-4 space-y-4">
          <div id="categories-checklist" class="space-y-2 max-h-48 overflow-y-auto pr-1">
            <!-- Categories radio-checklist loaded here -->
            <p class="text-slate-400 italic">Loading categories...</p>
          </div>

          <!-- Add New Category inline trigger -->
          <div class="border-t border-slate-100 pt-3">
            <button type="button" id="toggle-inline-cat-btn" class="text-blue-600 hover:text-blue-800 font-bold hover:underline cursor-pointer focus:outline-none flex items-center gap-1">
              + Add New Category
            </button>
            
            <div id="inline-cat-container" class="hidden mt-3 space-y-2.5 bg-slate-50 border p-3 rounded">
              <div>
                <input type="text" id="inline-cat-name" placeholder="Category Name" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2.5 py-1 focus:outline-none" />
              </div>
              <button type="button" id="inline-cat-add-btn" class="bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 font-bold px-2.5 py-1 rounded transition-all active:scale-[0.98]">
                Add
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Tags Widget -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Tags</h3>
        </div>
        <div class="p-4 space-y-2">
          <input id="tags" type="text" placeholder="Separate with commas" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2.5 py-1.5 focus:outline-none placeholder-slate-400 font-outfit" />
          <p class="text-[9px] text-slate-400 font-semibold uppercase tracking-wider">Example: ai, writing, blogging</p>
        </div>
      </div>

      <!-- Featured Image Widget -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Featured Image</h3>
        </div>
        <div class="p-4 text-center space-y-3 font-outfit">
          <input type="hidden" id="featured-image-url" />
          
          <div id="featured-image-preview-container" class="hidden border border-slate-200 rounded overflow-hidden relative group">
            <img id="featured-image-preview" src="" alt="Featured preview" class="w-full h-32 object-cover" />
          </div>

          <div>
            <button type="button" id="set-featured-image-btn" class="text-blue-600 hover:text-blue-800 font-bold hover:underline cursor-pointer focus:outline-none">
              Set featured image
            </button>
            <button type="button" id="remove-featured-image-btn" class="hidden text-red-650 hover:text-red-800 font-bold hover:underline cursor-pointer focus:outline-none">
              Remove featured image
            </button>
          </div>
        </div>
      </div>

      <!-- SEO Settings Card -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">SEO Settings</h3>
        </div>
        <div class="p-4 space-y-3.5 font-outfit">
          <div>
            <label class="block text-slate-500 font-medium mb-1">SEO Title Override</label>
            <input type="text" id="seo-title" placeholder="Leave empty for article title" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2.5 py-1.5 focus:outline-none placeholder-slate-400" />
          </div>
          <div>
            <label class="block text-slate-500 font-medium mb-1">SEO Description Override</label>
            <textarea id="seo-desc" rows="3" placeholder="Leave empty for excerpt" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2.5 py-1.5 focus:outline-none placeholder-slate-400 resize-none"></textarea>
          </div>
        </div>
      </div>

      <!-- Custom CSS Card -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Custom CSS Stylesheet</h3>
        </div>
        <div class="p-4 space-y-3.5 font-outfit">
          <div>
            <label class="block text-slate-500 font-medium mb-1">Custom CSS</label>
            <textarea id="custom-css" rows="6" placeholder="e.g. .article-content h2 { border-bottom-color: #7c3aed; }" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2.5 py-1.5 focus:outline-none placeholder-slate-400 font-mono text-[11px]"></textarea>
            <p class="text-[9px] text-slate-400 mt-1">This CSS ruleset targets child elements of `.article-content`. Do not wrap in style tags.</p>
          </div>
        </div>
      </div>

      <!-- Author -->
      <div class="bg-white border border-[#c3c4c7] rounded shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h3 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Author</h3>
        </div>
        <div class="p-4 font-outfit">
          <input type="text" id="author" class="w-full bg-white border border-[#8c8f94] text-slate-800 rounded px-2.5 py-1.5 focus:outline-none" required />
        </div>
      </div>

    </div>

  </form>

  <!-- Media Selector Modal Popup -->
  <div id="media-picker-modal" class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 hidden">
    <div class="bg-white rounded border border-[#c3c4c7] shadow-2xl max-w-4xl w-full h-[80vh] flex flex-col overflow-hidden relative font-outfit animate-in zoom-in-95 duration-200">
      
      <!-- Modal Header -->
      <div class="px-5 py-4 border-b border-[#c3c4c7] bg-slate-50 flex items-center justify-between shrink-0">
        <h2 class="text-sm font-bold text-slate-800 uppercase tracking-widest font-outfit">Select Featured Image</h2>
        <button type="button" id="close-media-modal-btn" class="text-slate-400 hover:text-slate-600 focus:outline-none cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="flex-1 overflow-y-auto p-5 grid grid-cols-3 sm:grid-cols-6 gap-4" id="modal-media-grid">
        <div class="col-span-full py-8 text-center text-slate-400">Loading files from Media Library...</div>
      </div>

      <!-- Modal Footer -->
      <div class="px-5 py-4 border-t border-[#c3c4c7] bg-slate-50 flex items-center justify-between shrink-0">
        <span class="text-[10px] text-slate-400 font-semibold" id="modal-selected-filename">No image selected</span>
        <div class="flex items-center gap-2">
          <button type="button" id="cancel-media-selection" class="bg-white hover:bg-slate-50 border border-[#8c8f94] text-slate-700 font-bold px-3.5 py-1.5 rounded text-xs">Cancel</button>
          <button type="button" id="confirm-media-selection" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-1.5 rounded text-xs select-none" disabled>Set Featured Image</button>
        </div>
      </div>

    </div>
  </div>

  <script>
    import { Editor } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';
    import Link from '@tiptap/extension-link';
    import Image from '@tiptap/extension-image';
    import Underline from '@tiptap/extension-underline';
    import Placeholder from '@tiptap/extension-placeholder';

    const form = document.getElementById('editor-form')!;
    const postId = form.getAttribute('data-post-id')!;

    let categories: any[] = [];
    let faqItems: { question: string; answer: string }[] = [];
    let allMedia: any[] = [];
    let selectedMediaUrl = '';
    let selectedMediaFilename = '';
    let viewMode = 'compose'; // compose, html
    let postDetails: any = null;

    // Clean up HMR clients
    if ((window as any).editorInstance) {
      (window as any).editorInstance.destroy();
    }

    // Initialize TipTap
    const editor = new Editor({
      element: document.querySelector('#wysiwyg-editor')!,
      extensions: [
        StarterKit,
        Underline,
        Link.configure({ openOnClick: false }),
        Image,
        Placeholder.configure({ placeholder: 'Start writing your story here...' }),
      ],
      content: '',
      onUpdate({ editor }) {
        const text = editor.getText();
        const count = text.trim() ? text.trim().split(/\s+/).length : 0;
        document.getElementById('word-count')!.textContent = `${count} words`;
      }
    });
    (window as any).editorInstance = editor;

    // Rich Text visual commands listeners
    document.getElementById('btn-bold')?.addEventListener('click', () => editor.chain().focus().toggleBold().run());
    document.getElementById('btn-italic')?.addEventListener('click', () => editor.chain().focus().toggleItalic().run());
    document.getElementById('btn-underline')?.addEventListener('click', () => editor.chain().focus().toggleUnderline().run());
    document.getElementById('btn-h2')?.addEventListener('click', () => editor.chain().focus().toggleHeading({ level: 2 }).run());
    document.getElementById('btn-h3')?.addEventListener('click', () => editor.chain().focus().toggleHeading({ level: 3 }).run());
    document.getElementById('btn-p')?.addEventListener('click', () => editor.chain().focus().setParagraph().run());
    document.getElementById('btn-ul')?.addEventListener('click', () => editor.chain().focus().toggleBulletList().run());
    document.getElementById('btn-ol')?.addEventListener('click', () => editor.chain().focus().toggleOrderedList().run());
    document.getElementById('btn-link')?.addEventListener('click', () => {
      const previousUrl = editor.getAttributes('link').href;
      const url = window.prompt('Enter link URL:', previousUrl);
      if (url === null) return;
      if (url === '') { editor.chain().focus().extendMarkRange('link').unsetLink().run(); return; }
      editor.chain().focus().extendMarkRange('link').setLink({ href: url }).run();
    });

    // Custom Boxes Injections
    document.getElementById('btn-tip')?.addEventListener('click', () => {
      editor.chain().focus().insertContent('<div class="tip-box"><p>💡 <strong>Tip:</strong> Enter recommendation...</p></div><p></p>').run();
    });
    document.getElementById('btn-warning')?.addEventListener('click', () => {
      editor.chain().focus().insertContent('<div class="warning-box"><p>⚠️ <strong>Warning:</strong> Enter critical pitfall...</p></div><p></p>').run();
    });
    document.getElementById('btn-info')?.addEventListener('click', () => {
      editor.chain().focus().insertContent('<div class="info-box"><p>ℹ️ <strong>Note:</strong> Enter extra context...</p></div><p></p>').run();
    });

    // Visual/HTML editor switcher logic
    const visualToolbar = document.getElementById('visual-toolbar')!;
    const wysiwygWrapper = document.getElementById('wysiwyg-editor')!;
    const rawHtmlEditor = document.getElementById('raw-html-editor') as HTMLTextAreaElement;
    
    const btnViewCompose = document.getElementById('btn-view-compose')!;
    const btnViewHtml = document.getElementById('btn-view-html')!;

    function setViewMode(mode: 'compose' | 'html') {
      viewMode = mode;
      if (mode === 'compose') {
        editor.commands.setContent(rawHtmlEditor.value);
        rawHtmlEditor.classList.add('hidden');
        wysiwygWrapper.classList.remove('hidden');
        visualToolbar.classList.remove('hidden');

        btnViewCompose.className = 'px-3 py-1 rounded bg-white border border-slate-200 text-slate-800 font-bold tracking-wide transition cursor-pointer shadow-sm';
        btnViewHtml.className = 'px-3 py-1 rounded hover:bg-slate-50 text-slate-550 hover:text-slate-800 font-semibold tracking-wide transition cursor-pointer';
      } else {
        rawHtmlEditor.value = editor.getHTML();
        wysiwygWrapper.classList.add('hidden');
        visualToolbar.classList.add('hidden');
        rawHtmlEditor.classList.remove('hidden');

        btnViewHtml.className = 'px-3 py-1 rounded bg-white border border-slate-200 text-slate-800 font-bold tracking-wide transition cursor-pointer shadow-sm';
        btnViewCompose.className = 'px-3 py-1 rounded hover:bg-slate-50 text-slate-550 hover:text-slate-800 font-semibold tracking-wide transition cursor-pointer';
      }
    }

    btnViewCompose.addEventListener('click', () => setViewMode('compose'));
    btnViewHtml.addEventListener('click', () => setViewMode('html'));

    // Handle Custom HTML layout checkbox
    const isCustomHtmlCheckbox = document.getElementById('is-custom-html') as HTMLInputElement;
    isCustomHtmlCheckbox.addEventListener('change', () => {
      if (isCustomHtmlCheckbox.checked) {
        setViewMode('html');
      } else {
        setViewMode('compose');
      }
    });

    // Populate dynamic permalink slug on title keyup
    const titleInput = document.getElementById('title') as HTMLInputElement;
    const permalinkSlug = document.getElementById('permalink-slug')!;
    const slugInput = document.getElementById('slug-input') as HTMLInputElement;
    
    titleInput.addEventListener('input', (e) => {
      const generated = (e.target as HTMLInputElement).value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      permalinkSlug.textContent = generated || 'slug-name';
      slugInput.value = generated;
    });

    // Slug editor trigger
    const editSlugBtn = document.getElementById('edit-slug-btn')!;
    const slugEditContainer = document.getElementById('slug-edit-container')!;
    const saveSlugBtn = document.getElementById('save-slug-btn')!;
    const cancelSlugBtn = document.getElementById('cancel-slug-btn')!;

    editSlugBtn.addEventListener('click', () => {
      slugEditContainer.classList.remove('hidden');
      slugEditContainer.classList.add('inline-flex');
      permalinkSlug.classList.add('hidden');
      editSlugBtn.classList.add('hidden');
      slugInput.focus();
    });

    saveSlugBtn.addEventListener('click', () => {
      const val = slugInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      permalinkSlug.textContent = val || 'slug-name';
      slugEditContainer.classList.add('hidden');
      slugEditContainer.classList.remove('inline-flex');
      permalinkSlug.classList.remove('hidden');
      editSlugBtn.classList.remove('hidden');
    });

    cancelSlugBtn.addEventListener('click', () => {
      slugEditContainer.classList.add('hidden');
      slugEditContainer.classList.remove('inline-flex');
      permalinkSlug.classList.remove('hidden');
      editSlugBtn.classList.remove('hidden');
      slugInput.value = permalinkSlug.textContent || '';
    });

    // Load Categories
    async function loadCategories() {
      try {
        const rCats = await fetch('/api/admin/categories');
        if (rCats.ok) {
          categories = await rCats.json();
          const checkedRadio = document.querySelector('input[name="post-category"]:checked') as HTMLInputElement;
          const selectedName = checkedRadio ? checkedRadio.value : (postDetails ? postDetails.category : 'AI Tools');
          renderCategoriesChecklist(selectedName);
        }
      } catch (err) {
        console.error(err);
      }
    }

    // Load Article and populate inputs
    async function loadArticle() {
      try {
        // Load categories list first
        await loadCategories();

        // Load article details
        const rPost = await fetch(`/api/admin/posts?id=${postId}`);
        if (!rPost.ok) throw new Error('Post not found');
        postDetails = await rPost.json();

        renderCategoriesChecklist(postDetails.category);
        populateEditor(postDetails);

        // Hide loader, show editor layout
        document.getElementById('loading-state')!.classList.add('hidden');
        form.classList.remove('hidden');
        form.classList.add('grid');

      } catch (err) {
        console.error(err);
        document.getElementById('loading-state')!.innerHTML = `<div class="p-6 text-red-650 font-bold">Failed to load article details. <a href="/admin/posts" class="underline text-blue-600">Back to all posts</a></div>`;
      }
    }

    function renderCategoriesChecklist(activeCategoryName: string) {
      const container = document.getElementById('categories-checklist')!;
      if (!categories.length) {
        container.innerHTML = '<p class="text-slate-400 italic">No categories found.</p>';
        return;
      }

      container.innerHTML = categories.map(c => `
        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input type="radio" name="post-category" value="${c.name}" ${c.name === activeCategoryName ? 'checked' : ''} class="rounded border-slate-350 text-blue-600 focus:ring-blue-500 w-3.5 h-3.5" />
          <span class="text-slate-700 font-medium">${c.name}</span>
        </label>
      `).join('');
    }

    // Add category inline toggle
    const toggleCatBtn = document.getElementById('toggle-inline-cat-btn')!;
    const inlineCatContainer = document.getElementById('inline-cat-container')!;
    const addCatBtn = document.getElementById('inline-cat-add-btn') as HTMLButtonElement;
    const catNameInput = document.getElementById('inline-cat-name') as HTMLInputElement;

    toggleCatBtn.addEventListener('click', () => {
      inlineCatContainer.classList.toggle('hidden');
      catNameInput.focus();
    });

    addCatBtn.addEventListener('click', async () => {
      const name = catNameInput.value.trim();
      if (!name) return;
      
      const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      addCatBtn.disabled = true;

      try {
        const res = await fetch('/api/admin/categories', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, slug, description: '' })
        });
        
        if (res.ok) {
          catNameInput.value = '';
          inlineCatContainer.classList.add('hidden');
          await loadCategories();
          
          // Select newly created category checkbox
          const radio = document.querySelector(`input[name="post-category"][value="${name}"]`) as HTMLInputElement;
          if (radio) radio.checked = true;
        } else {
          const d = await res.json();
          alert(d.error || 'Failed to add category');
        }
      } catch (err) {
        console.error(err);
        alert('Failed to add category');
      } finally {
        addCatBtn.disabled = false;
      }
    });

    function populateEditor(p: any) {
      titleInput.value = p.title || '';
      permalinkSlug.textContent = p.slug || '';
      slugInput.value = p.slug || '';
      
      // Update preview link
      const previewBtn = document.getElementById('view-article-btn') as HTMLAnchorElement;
      const catSlug = (p.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-');
      previewBtn.href = `/${catSlug}/${p.slug}`;
      previewBtn.classList.remove('hidden');

      (document.getElementById('excerpt') as HTMLTextAreaElement).value = p.excerpt || '';
      
      // Setup HTML Layout checked
      isCustomHtmlCheckbox.checked = !!p.isCustomHtml;
      
      // Setup visual editor or HTML contents
      if (p.isCustomHtml) {
        rawHtmlEditor.value = p.content || '';
        setViewMode('html');
      } else {
        editor.commands.setContent(p.content || '');
      }

      // Settings
      (document.getElementById('status') as HTMLSelectElement).value = p.status || 'draft';
      (document.getElementById('tags') as HTMLInputElement).value = (p.tags || []).join(', ');
      (document.getElementById('seo-title') as HTMLInputElement).value = p.meta_title || '';
      (document.getElementById('seo-desc') as HTMLTextAreaElement).value = p.meta_description || '';
      (document.getElementById('custom-css') as HTMLTextAreaElement).value = p.customCss || '';
      (document.getElementById('author') as HTMLInputElement).value = p.author || 'Editorial Team';

      if (p.publishDate) {
        // Slice datetime-local formatted string (YYYY-MM-DDTHH:MM)
        (document.getElementById('publish-date') as HTMLInputElement).value = p.publishDate.substring(0, 16);
      }

      // Featured Image URL
      if (p.featuredImage) {
        featuredUrlInput.value = p.featuredImage;
        featuredPreview.src = p.featuredImage;
        featuredPreviewContainer.classList.remove('hidden');
        removeFeaturedBtn.classList.remove('hidden');
        setFeaturedBtn.classList.add('hidden');
      }

      // Populate FAQ items
      if (p.faq_items && p.faq_items.length) {
        faqEmptyState.classList.add('hidden');
        p.faq_items.forEach((item: any, idx: number) => {
          faqItems.push(item);
          const row = document.createElement('div');
          row.id = `faq-row-${idx}`;
          row.className = 'bg-slate-50 border border-slate-200 p-3.5 rounded relative space-y-2.5';
          row.innerHTML = `
            <button type="button" onclick="window.removeFaqRow(${idx})" class="absolute top-2 right-2 text-slate-400 hover:text-red-650 focus:outline-none cursor-pointer" title="Remove FAQ">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <div>
              <label class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Question</label>
              <input type="text" id="faq-q-${idx}" value="${item.question}" class="w-full bg-white border border-slate-300 rounded px-2.5 py-1 focus:outline-none" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Answer</label>
              <textarea id="faq-a-${idx}" rows="2" class="w-full bg-white border border-slate-300 rounded px-2.5 py-1 focus:outline-none resize-none">${item.answer}</textarea>
            </div>
          `;
          faqList.appendChild(row);
        });
      }
    }

    // FAQs list operations
    const addFaqBtn = document.getElementById('add-faq-item')!;
    const faqList = document.getElementById('faq-items-list')!;
    const faqEmptyState = document.getElementById('faq-empty-state')!;

    addFaqBtn.addEventListener('click', () => {
      faqEmptyState.classList.add('hidden');
      const idx = faqItems.length;
      faqItems.push({ question: '', answer: '' });

      const row = document.createElement('div');
      row.id = `faq-row-${idx}`;
      row.className = 'bg-slate-50 border border-slate-200 p-3.5 rounded relative space-y-2.5';
      row.innerHTML = `
        <button type="button" onclick="window.removeFaqRow(${idx})" class="absolute top-2 right-2 text-slate-400 hover:text-red-650 focus:outline-none cursor-pointer" title="Remove FAQ">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <div>
          <label class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Question</label>
          <input type="text" id="faq-q-${idx}" placeholder="e.g. What is Mershal CMS?" class="w-full bg-white border border-slate-300 rounded px-2.5 py-1 focus:outline-none" />
        </div>
        <div>
          <label class="block text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-1">Answer</label>
          <textarea id="faq-a-${idx}" rows="2" placeholder="FAQ Answer content..." class="w-full bg-white border border-slate-300 rounded px-2.5 py-1 focus:outline-none resize-none"></textarea>
        </div>
      `;

      faqList.appendChild(row);
      document.getElementById(`faq-q-${idx}`)?.focus();
    });

    (window as any).removeFaqRow = function(idx: number) {
      document.getElementById(`faq-row-${idx}`)?.remove();
      faqItems[idx] = null as any; // mark deleted
      
      const activeRows = faqList.querySelectorAll('div[id^="faq-row-"]');
      if (!activeRows.length) {
        faqEmptyState.classList.remove('hidden');
      }
    };

    // Media Picker Modal operations
    const mediaModal = document.getElementById('media-picker-modal')!;
    const closeMediaModalBtn = document.getElementById('close-media-modal-btn')!;
    const cancelMediaBtn = document.getElementById('cancel-media-selection')!;
    const confirmMediaBtn = document.getElementById('confirm-media-selection') as HTMLButtonElement;
    const modalMediaGrid = document.getElementById('modal-media-grid')!;
    const modalSelectedFilename = document.getElementById('modal-selected-filename')!;
    
    const setFeaturedBtn = document.getElementById('set-featured-image-btn')!;
    const removeFeaturedBtn = document.getElementById('remove-featured-image-btn')!;
    const featuredPreviewContainer = document.getElementById('featured-image-preview-container')!;
    const featuredPreview = document.getElementById('featured-image-preview') as HTMLImageElement;
    const featuredUrlInput = document.getElementById('featured-image-url') as HTMLInputElement;

    let mediaPickerTarget = 'featured'; // 'featured' or 'editor'

    document.getElementById('btn-insert-image')?.addEventListener('click', () => {
      mediaPickerTarget = 'editor';
      openMediaPicker();
    });

    setFeaturedBtn.addEventListener('click', () => {
      mediaPickerTarget = 'featured';
      openMediaPicker();
    });

    async function openMediaPicker() {
      mediaModal.classList.remove('hidden');
      modalSelectedFilename.textContent = 'No image selected';
      confirmMediaBtn.disabled = true;
      selectedMediaUrl = '';
      selectedMediaFilename = '';

      try {
        const res = await fetch('/api/admin/media');
        if (res.ok) {
          allMedia = await res.json();
          renderModalGrid(allMedia);
        } else {
          modalMediaGrid.innerHTML = '<div class="col-span-full py-8 text-center text-red-650 font-bold">Failed to retrieve media library.</div>';
        }
      } catch (err) {
        modalMediaGrid.innerHTML = '<div class="col-span-full py-8 text-center text-red-650 font-bold">Failed to retrieve media library.</div>';
      }
    }

    function renderModalGrid(items: any[]) {
      if (!items.length) {
        modalMediaGrid.innerHTML = '<div class="col-span-full py-12 text-center text-slate-450 font-medium">No files found. <a href="/admin/media?action=upload" target="_blank" class="text-blue-600 underline font-bold">Upload files first</a></div>';
        return;
      }

      modalMediaGrid.innerHTML = items.map((item, idx) => `
        <div onclick="window.selectMediaItem(${idx})" id="picker-item-${idx}" class="aspect-square bg-slate-100 border border-slate-200 hover:border-blue-600 rounded overflow-hidden cursor-pointer relative shadow-sm select-none">
          <img src="${item.url}" alt="${item.name}" class="w-full h-full object-cover" />
        </div>
      `).join('');
    }

    (window as any).selectMediaItem = function(idx: number) {
      document.querySelectorAll('[id^="picker-item-"]').forEach(el => el.classList.remove('ring-4', 'ring-blue-600', 'border-blue-600'));
      
      const item = allMedia[idx];
      selectedMediaUrl = item.url;
      selectedMediaFilename = item.name.split('/').pop();

      document.getElementById(`picker-item-${idx}`)!.classList.add('ring-4', 'ring-blue-600', 'border-blue-600');
      
      modalSelectedFilename.textContent = `Selected: ${selectedMediaFilename}`;
      confirmMediaBtn.disabled = false;
    };

    function closeMediaModal() {
      mediaModal.classList.add('hidden');
    }

    closeMediaModalBtn.addEventListener('click', closeMediaModal);
    cancelMediaBtn.addEventListener('click', closeMediaModal);
    mediaModal.addEventListener('click', (e) => { if (e.target === mediaModal) closeMediaModal(); });

    confirmMediaBtn.addEventListener('click', () => {
      if (!selectedMediaUrl) return;

      if (mediaPickerTarget === 'featured') {
        featuredUrlInput.value = selectedMediaUrl;
        featuredPreview.src = selectedMediaUrl;
        featuredPreviewContainer.classList.remove('hidden');
        removeFeaturedBtn.classList.remove('hidden');
        setFeaturedBtn.classList.add('hidden');
      } else {
        editor.chain().focus().setImage({ src: selectedMediaUrl }).run();
      }

      closeMediaModal();
    });

    removeFeaturedBtn.addEventListener('click', () => {
      featuredUrlInput.value = '';
      featuredPreview.src = '';
      featuredPreviewContainer.classList.add('hidden');
      removeFeaturedBtn.classList.add('hidden');
      setFeaturedBtn.classList.remove('hidden');
    });

    // Move to Trash
    document.getElementById('trash-post-btn')?.addEventListener('click', async () => {
      if (!confirm(`Are you sure you want to permanently delete "${postDetails.title}"?\nThis cannot be undone.`)) return;
      
      try {
        const res = await fetch(`/api/admin/posts?id=${postId}`, { method: 'DELETE' });
        if (res.ok) {
          showAlert('Article deleted successfully. Redirecting...', 'success');
          setTimeout(() => {
            window.location.href = '/admin/posts';
          }, 1200);
        } else {
          showAlert('Failed to delete article', 'error');
        }
      } catch (err) {
        console.error(err);
        showAlert('An error occurred during deletion', 'error');
      }
    });

    // Form Submission: Save Draft or Update
    const alertEl = document.getElementById('alert')!;
    
    async function submitPost() {
      const title = titleInput.value.trim();
      const slug = permalinkSlug.textContent?.trim() || '';
      const excerpt = (document.getElementById('excerpt') as HTMLTextAreaElement).value.trim();
      const content = viewMode === 'compose' ? editor.getHTML() : rawHtmlEditor.value;
      const customCss = (document.getElementById('custom-css') as HTMLTextAreaElement).value.trim();
      
      const selectedCategoryRadio = document.querySelector('input[name="post-category"]:checked') as HTMLInputElement;
      const category = selectedCategoryRadio ? selectedCategoryRadio.value : 'AI Tools';
      
      const tags = (document.getElementById('tags') as HTMLInputElement).value.split(',').map(t => t.trim()).filter(Boolean);
      const featuredImage = featuredUrlInput.value;
      const author = (document.getElementById('author') as HTMLInputElement).value.trim();
      
      const isCustomHtml = isCustomHtmlCheckbox.checked;
      const publishDate = (document.getElementById('publish-date') as HTMLInputElement).value;
      const status = (document.getElementById('status') as HTMLSelectElement).value;

      // Compile FAQs
      const compiledFaqs = faqItems
        .map((item, idx) => {
          if (item === null) return null;
          const qInput = document.getElementById(`faq-q-${idx}`) as HTMLInputElement;
          const aInput = document.getElementById(`faq-a-${idx}`) as HTMLTextAreaElement;
          const q = qInput ? qInput.value.trim() : '';
          const a = aInput ? aInput.value.trim() : '';
          return { question: q, answer: a };
        })
        .filter((item): item is { question: string; answer: string } => item !== null && item.question !== '' && item.answer !== '');

      if (!title) {
        showAlert('Title is required', 'error');
        return;
      }

      const publishBtn = document.getElementById('publish-btn') as HTMLButtonElement;
      publishBtn.disabled = true;
      publishBtn.textContent = 'Updating...';

      try {
        const res = await fetch('/api/admin/posts', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: postId,
            title,
            slug,
            excerpt,
            content,
            category,
            tags,
            featuredImage,
            author,
            status,
            publishDate: publishDate ? new Date(publishDate).toISOString() : null,
            faq_items: compiledFaqs,
            isCustomHtml,
            customCss
          })
        });

        const data = await res.json();
        
        if (res.ok) {
          showAlert(`Article successfully updated!`, 'success');
          // Update preview link and slug
          const catSlug = category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
          (document.getElementById('view-article-btn') as HTMLAnchorElement).href = `/${catSlug}/${slug}`;
          (document.getElementById('header-slug')!).textContent = `/${catSlug}/${slug}`;
        } else {
          throw new Error(data.error || 'Failed to update article');
        }
      } catch (err: any) {
        console.error('Post update failed:', err);
        showAlert(err.message || 'Failed to update post details.', 'error');
      } finally {
        publishBtn.disabled = false;
        publishBtn.textContent = 'Update';
      }
    }

    document.getElementById('save-draft-btn')?.addEventListener('click', async () => {
      (document.getElementById('status') as HTMLSelectElement).value = 'draft';
      await submitPost();
    });
    
    document.getElementById('publish-btn')?.addEventListener('click', async (e) => {
      e.preventDefault();
      await submitPost();
    });

    function showAlert(msg: string, type: 'success' | 'error') {
      alertEl.textContent = msg;
      alertEl.className = `mb-5 p-4 rounded text-xs font-semibold font-outfit border animate-in fade-in duration-200 ${type === 'success' ? 'bg-emerald-50 text-emerald-700 border-emerald-250' : 'bg-red-50 text-red-700 border-red-200'}`;
      alertEl.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Initialize page details
    loadArticle();
  </script>
</AdminLayout>
