---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { adminDb } from '../../../lib/firebase-admin';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');

// Load categories on server side
let categories: any[] = [];
let hasGemini = false;
let hasOpenAI = false;

// 10 Default Categories (matching those in api/admin/categories.ts)
const defaults = [
  { id: 'ai-tools', name: 'AI Tools', slug: 'ai-tools' },
  { id: 'technology-guides', name: 'Technology Guides', slug: 'technology-guides' },
  { id: 'freelancing', name: 'Freelancing', slug: 'freelancing' },
  { id: 'remote-work', name: 'Remote Work', slug: 'remote-work' },
  { id: 'side-hustles', name: 'Side Hustles', slug: 'side-hustles' },
  { id: 'software-reviews', name: 'Software Reviews', slug: 'software-reviews' },
  { id: 'seo-blogging', name: 'SEO & Blogging', slug: 'seo-blogging' },
  { id: 'web-development', name: 'Web Development', slug: 'web-development' },
  { id: 'startup-stories', name: 'Startup Stories', slug: 'startup-stories' },
  { id: 'productivity', name: 'Productivity', slug: 'productivity' }
];

if (adminDb) {
  try {
    // Fetch custom categories
    const categoriesSnapshot = await adminDb.collection('categories').get();
    let custom = categoriesSnapshot.docs.map(doc => ({
      id: doc.id,
      name: doc.data().name || doc.id,
      slug: doc.data().slug || ''
    }));

    // Filter out custom categories that duplicate default ones by slug or name
    custom = custom.filter(c => !defaults.some(d => d.slug === c.slug || d.name.toLowerCase() === c.name.toLowerCase()));

    // Merge default and custom categories, sorting them alphabetically
    categories = [...defaults, ...custom].sort((a, b) => a.name.localeCompare(b.name));

    // Fetch API Configuration status for badges
    const settingsDoc = await adminDb.collection('settings').doc('general').get();
    const settings = settingsDoc.exists ? settingsDoc.data() : {};
    
    hasGemini = !!(settings?.geminiApiKey || process.env.GEMINI_API_KEY || import.meta.env.GEMINI_API_KEY);
    hasOpenAI = !!(settings?.openaiApiKey || process.env.OPENAI_API_KEY || import.meta.env.OPENAI_API_KEY);
  } catch (error) {
    console.error('Failed to pre-fetch server data:', error);
  }
}
---

<AdminLayout title="AI Auto-Poster Console" activeNav="auto-poster">
  <!-- Header -->
  <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-black font-outfit text-slate-800 tracking-tight">AI Auto-Poster</h1>
      <p class="text-slate-500 text-xs mt-0.5 font-outfit font-medium">Automatic user-problem discovery, multi-stage article compiler, and instant search indexing</p>
    </div>
    
    <!-- API Connection State Badges -->
    <div class="flex gap-2 shrink-0">
      <div class="flex items-center gap-1.5 px-2.5 py-1 rounded border bg-white shadow-sm text-[10px] font-outfit">
        <span class="font-bold text-slate-500">Gemini API:</span>
        {hasGemini ? (
          <span class="px-1.5 py-0.2 rounded bg-emerald-50 text-emerald-700 border border-emerald-200 font-bold uppercase tracking-wider text-[8px]">Connected</span>
        ) : (
          <span class="px-1.5 py-0.2 rounded bg-red-50 text-red-700 border border-red-200 font-bold uppercase tracking-wider text-[8px]">Missing</span>
        )}
      </div>
      <div class="flex items-center gap-1.5 px-2.5 py-1 rounded border bg-white shadow-sm text-[10px] font-outfit">
        <span class="font-bold text-slate-500">OpenAI API:</span>
        {hasOpenAI ? (
          <span class="px-1.5 py-0.2 rounded bg-emerald-50 text-emerald-700 border border-emerald-200 font-bold uppercase tracking-wider text-[8px]">Connected</span>
        ) : (
          <span class="px-1.5 py-0.2 rounded bg-red-50 text-red-700 border border-red-200 font-bold uppercase tracking-wider text-[8px]">Missing</span>
        )}
      </div>
    </div>
  </div>

  <div id="status-banner" class="hidden mb-5 p-4 rounded text-xs font-semibold font-outfit border animate-in fade-in duration-200"></div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Generation Configuration Form -->
    <div class="bg-white border border-[#c3c4c7] rounded-md shadow-[0_1px_3px_rgba(0,0,0,0.04)] lg:col-span-2 space-y-6 flex flex-col justify-between">
      <div>
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
          <h2 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit">Create New Article</h2>
        </div>
        <form id="auto-poster-form" class="p-6 space-y-4 font-outfit text-xs">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Keyword Input -->
            <div class="md:col-span-2">
              <label for="keyword" class="block text-[10px] font-bold text-slate-600 uppercase tracking-wider mb-1.5">Root Keyword or Problem Topic</label>
              <input type="text" id="keyword" placeholder="e.g. Astro Sitemap, React Hydration, CSS Grid" class="w-full bg-white border border-slate-300 text-slate-800 rounded px-3 py-2 text-xs focus:outline-none focus:border-blue-500 placeholder-slate-400 font-medium" required />
              <p class="text-[9px] text-slate-400 mt-1">The system will scrape Google autocomplete for this keyword to target real user search queries.</p>
            </div>

            <!-- AI Engine Selector -->
            <div>
              <label for="provider" class="block text-[10px] font-bold text-slate-600 uppercase tracking-wider mb-1.5">AI Writing Engine</label>
              <select id="provider" class="w-full bg-white border border-slate-300 text-slate-800 rounded px-3 py-2 text-xs focus:outline-none focus:border-blue-500 font-medium cursor-pointer">
                <option value="gemini:gemini-2.5-flash">Google Gemini 2.5 Flash (Fast & Cost-Efficient)</option>
                <option value="gemini:gemini-2.5-pro">Google Gemini 2.5 Pro (Highly Creative & In-Depth)</option>
                <option value="openai:gpt-4o-mini">OpenAI GPT-4o Mini (Fast & Standard)</option>
                <option value="openai:gpt-4o">OpenAI GPT-4o (Premium Editorial Quality)</option>
                <option value="openai:o3-mini">OpenAI o3-mini (Smart Logical/Reasoning)</option>
              </select>
            </div>

            <!-- Target Category -->
            <div>
              <label for="category" class="block text-[10px] font-bold text-slate-600 uppercase tracking-wider mb-1.5">Target Category</label>
              <select id="category" class="w-full bg-white border border-slate-300 text-slate-800 rounded px-3 py-2 text-xs focus:outline-none focus:border-blue-500 font-medium cursor-pointer">
                {categories.map((cat) => (
                  <option value={cat.name}>{cat.name}</option>
                ))}
                {categories.length === 0 && <option value="AI Tools">AI Tools</option>}
              </select>
            </div>

            <!-- Publishing Status -->
            <div>
              <label for="status" class="block text-[10px] font-bold text-slate-600 uppercase tracking-wider mb-1.5">Publish Status</label>
              <select id="status" class="w-full bg-white border border-slate-300 text-slate-800 rounded px-3 py-2 text-xs focus:outline-none focus:border-blue-500 font-medium cursor-pointer">
                <option value="published">Publish Immediately (URL_UPDATED notified)</option>
                <option value="draft">Save as Draft (Review in Admin list)</option>
              </select>
            </div>

            <!-- Publishing Editor Selector -->
            <div>
              <label for="author" class="block text-[10px] font-bold text-slate-600 uppercase tracking-wider mb-1.5">Publishing Editor</label>
              <select id="author" class="w-full bg-white border border-slate-300 text-slate-800 rounded px-3 py-2 text-xs focus:outline-none focus:border-blue-500 font-medium cursor-pointer">
                <option value="Archit">Archit (Lead Fullstack Architect)</option>
                <option value="Mahi">Mahi (Senior SEO Strategist)</option>
                <option value="Tiyasha">Tiyasha (Digital Productivity Lead)</option>
                <option value="Alisa">Alisa (SaaS Product Analyst)</option>
              </select>
            </div>
          </div>

          <div class="pt-2 flex justify-start">
            <button type="submit" id="submit-btn" class="bg-[#2271b1] hover:bg-[#135e96] text-white px-5 py-2.5 rounded text-xs font-bold transition-all active:scale-[0.98] cursor-pointer flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
              Run Generation Pipeline
            </button>
          </div>
        </form>
      </div>

      <!-- Live Terminal Progress Console -->
      <div id="live-console-card" class="hidden border-t p-6 space-y-3 bg-slate-50/50">
        <div class="flex items-center justify-between text-[10px] font-bold text-slate-500 font-outfit uppercase tracking-wider">
          <span>Writing Pipeline Live Activity Logs</span>
          <span id="progress-label" class="font-mono text-blue-600">0%</span>
        </div>
        
        <!-- Custom Progress Bar -->
        <div class="w-full bg-slate-200 rounded-full h-1.5 dark:bg-slate-700 overflow-hidden shadow-inner">
          <div id="progress-bar" class="bg-blue-600 h-1.5 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>

        <pre id="terminal-console" class="bg-slate-900 border border-slate-800 text-emerald-400 p-4 rounded font-mono text-[10px] leading-relaxed h-60 overflow-y-auto max-w-full whitespace-pre-wrap select-text shadow-inner">Console ready. Spawning listener...</pre>
      </div>
    </div>

    <!-- Right Sidebar Information Card -->
    <div class="bg-white border border-[#c3c4c7] rounded-md shadow-[0_1px_3px_rgba(0,0,0,0.04)] font-outfit text-xs leading-relaxed space-y-4">
      <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
        <h2 class="text-xs font-bold text-slate-650 uppercase tracking-widest">Pipeline Architect</h2>
      </div>
      <div class="p-6 text-slate-650 space-y-4">
        <p>To produce <strong>100% Adsense friendly, high-value, and SEO-optimized content</strong>, the system executes a strict multi-stage generation sequence:</p>
        
        <div class="space-y-3">
          <div class="flex gap-2">
            <span class="text-blue-600 font-bold shrink-0">1. Autocomplete Scrape:</span>
            <span>Crawls Google Chrome autocomplete API for keyword suggestion branches, selecting highly searched queries.</span>
          </div>
          <div class="flex gap-2">
            <span class="text-blue-600 font-bold shrink-0">2. Outline Framing:</span>
            <span>AI plans out logical headings, tags, and FAQ schema properties before writing.</span>
          </div>
          <div class="flex gap-2">
            <span class="text-blue-600 font-bold shrink-0">3. Loop Compilation:</span>
            <span>Instead of a single shallow draft, the AI writes section-by-section to generate details, code, and structured tutorials (1,500 - 3,000+ words).</span>
          </div>
          <div class="flex gap-2">
            <span class="text-blue-600 font-bold shrink-0">4. Visual Sourcing:</span>
            <span>Auto searches Unsplash for high-res tech featured images and attaches them.</span>
          </div>
          <div class="flex gap-2">
            <span class="text-blue-600 font-bold shrink-0">5. Instant Indexing:</span>
            <span>Auto index submissions ping Google instantly so new pages get crawled under 24 hours.</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Historical Run Log Table -->
  <div class="bg-white border border-[#c3c4c7] rounded-md shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden">
    <div class="px-4 py-3 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
      <h2 class="text-xs font-bold text-slate-650 uppercase tracking-widest font-outfit font-bold">Auto-Poster Transaction History</h2>
      <button id="refresh-history-btn" class="text-blue-600 hover:text-blue-800 text-[10px] font-bold font-outfit flex items-center gap-1 cursor-pointer">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18.2"/></svg>
        Refresh Runs
      </button>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead>
          <tr class="bg-slate-50/75 border-b border-slate-200 text-[10px] font-bold text-slate-450 uppercase tracking-wider select-none font-outfit">
            <th class="p-3 pl-4">Timestamp</th>
            <th class="p-3">Keyword</th>
            <th class="p-3">Engine</th>
            <th class="p-3">Resulting Article</th>
            <th class="p-3">Word Count</th>
            <th class="p-3">Status</th>
            <th class="p-3 pr-4">Action</th>
          </tr>
        </thead>
        <tbody id="history-tbody" class="divide-y divide-slate-100 font-outfit">
          <tr>
            <td colspan="7" class="p-8 text-center text-slate-400">
              <svg class="w-5 h-5 animate-spin mx-auto text-blue-650 mb-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              <span>Fetching history log entries...</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    const form = document.getElementById('auto-poster-form') as HTMLFormElement;
    const keywordInput = document.getElementById('keyword') as HTMLInputElement;
    const categorySelect = document.getElementById('category') as HTMLSelectElement;
    const providerSelect = document.getElementById('provider') as HTMLSelectElement;
    const statusSelect = document.getElementById('status') as HTMLSelectElement;
    const authorSelect = document.getElementById('author') as HTMLSelectElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    
    const consoleCard = document.getElementById('live-console-card')!;
    const consoleEl = document.getElementById('terminal-console')!;
    const progressBar = document.getElementById('progress-bar')!;
    const progressLabel = document.getElementById('progress-label')!;
    const banner = document.getElementById('status-banner')!;
    const tbody = document.getElementById('history-tbody')!;

    let pollInterval: any = null;

    // Show alert banner
    function showBanner(msg: string, type: 'success' | 'error') {
      banner.textContent = msg;
      banner.className = `mb-5 p-4 rounded text-xs font-semibold font-outfit border animate-in fade-in duration-200 ${type === 'success' ? 'bg-emerald-50 text-emerald-700 border-emerald-250' : 'bg-red-50 text-red-700 border-red-200'}`;
      banner.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Enable/Disable form inputs
    function toggleFormDisabled(disabled: boolean) {
      keywordInput.disabled = disabled;
      categorySelect.disabled = disabled;
      providerSelect.disabled = disabled;
      statusSelect.disabled = disabled;
      authorSelect.disabled = disabled;
      submitBtn.disabled = disabled;
      if (disabled) {
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
      } else {
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
    }

    // Escape HTML to prevent injection in code outputs
    function escapeHtml(unsafe: string): string {
      return unsafe
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    // Fetch and render historical run logs
    async function loadRunsList() {
      try {
        const res = await fetch('/api/admin/auto-poster');
        if (res.ok) {
          const runs = await res.json();
          if (runs.length === 0) {
            tbody.innerHTML = `
              <tr>
                <td colspan="7" class="p-8 text-center text-slate-450 font-outfit">No previously auto-generated articles found. Start one above!</td>
              </tr>
            `;
            return;
          }

          tbody.innerHTML = runs.map((run: any) => {
            const dateStr = new Date(run.timestamp).toLocaleString('en-US', {
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });

             let modelLabel = run.model || (run.provider === 'openai' ? 'GPT-4o Mini' : 'Gemini 2.5');
             // Format model label for readability
             if (modelLabel === 'gpt-4o-mini') modelLabel = 'GPT-4o Mini';
             if (modelLabel === 'gpt-4o') modelLabel = 'GPT-4o';
             if (modelLabel === 'o3-mini') modelLabel = 'o3-mini';
             if (modelLabel === 'gemini-2.5-flash') modelLabel = 'Gemini 2.5 Flash';
             if (modelLabel === 'gemini-2.5-pro') modelLabel = 'Gemini 2.5 Pro';

             const isOp = run.provider === 'openai';
             const engineBadge = `<span class="px-1.5 py-0.5 rounded text-[9px] font-bold font-mono ${isOp ? 'bg-purple-50 text-purple-700 border border-purple-200' : 'bg-blue-50 text-blue-700 border border-blue-200'}">${escapeHtml(modelLabel)}</span>`;

            let statusBadge = '';
            if (run.status === 'success') {
              statusBadge = '<span class="px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700 border border-emerald-250 text-[9px] font-bold uppercase tracking-wider">Success</span>';
            } else if (run.status === 'failed') {
              statusBadge = '<span class="px-1.5 py-0.5 rounded bg-red-50 text-red-700 border border-red-200 text-[9px] font-bold uppercase tracking-wider" title="' + escapeHtml(run.error) + '">Failed</span>';
            } else {
              statusBadge = '<span class="px-1.5 py-0.5 rounded bg-yellow-50 text-yellow-750 border border-yellow-200 text-[9px] font-bold uppercase tracking-wider animate-pulse">Running</span>';
            }

            const articleLink = run.articleSlug
              ? `<a href="/${run.category.toLowerCase().replace(/[^a-z0-9]+/g, '-')}/${run.articleSlug}" target="_blank" class="text-blue-650 hover:underline font-semibold font-outfit">${escapeHtml(run.articleTitle || 'View Post')}</a>`
              : `<span class="text-slate-400 font-medium italic">Pending compilation</span>`;

            const actionBtn = run.articleId
              ? `<a href="/admin/posts/edit?id=${run.articleId}" class="text-blue-600 hover:text-blue-800 font-bold hover:underline">Edit</a>`
              : `<span class="text-slate-400 font-medium">-</span>`;

            return `
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="p-3 pl-4 text-slate-500 font-mono text-[10px] whitespace-nowrap">${dateStr}</td>
                <td class="p-3 font-semibold text-slate-700 max-w-xs truncate" title="${escapeHtml(run.keyword)}">${escapeHtml(run.keyword)}</td>
                <td class="p-3">${engineBadge}</td>
                <td class="p-3">${articleLink}</td>
                <td class="p-3 font-mono text-[10px] text-slate-500">${run.wordCount || '-'}</td>
                <td class="p-3">${statusBadge}</td>
                <td class="p-3 pr-4">${actionBtn}</td>
              </tr>
            `;
          }).join('');
        }
      } catch (err: any) {
        console.error('Failed to load history list:', err);
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="p-8 text-center text-red-600 font-semibold">Failed to fetch transactions logs: ${err.message || 'connection error'}</td>
          </tr>
        `;
      }
    }

    // Poll current active generation run
    function pollRunStatus(runId: string) {
      if (pollInterval) clearInterval(pollInterval);

      pollInterval = setInterval(async () => {
        try {
          const res = await fetch(`/api/admin/auto-poster?runId=${runId}`);
          if (res.ok) {
            const run = await res.json();
            
            // Render logs to Console
            consoleEl.textContent = run.logs.join('\n');
            consoleEl.scrollTop = consoleEl.scrollHeight; // Auto-scroll to bottom
            
            // Calculate progress percentage
            let pct = 0;
            if (run.status === 'running') {
              // Smooth progress bar calculation based on logs length (normal runs produce about 12 logging steps)
              pct = Math.min(95, Math.round((run.logs.length / 14) * 100));
            } else if (run.status === 'success') {
              pct = 100;
              clearInterval(pollInterval);
              toggleFormDisabled(false);
              showBanner('AI Article compile process finished successfully! The article is now saved.', 'success');
              loadRunsList();
            } else if (run.status === 'failed') {
              pct = 100;
              clearInterval(pollInterval);
              toggleFormDisabled(false);
              showBanner(`Pipeline aborted: ${run.error || 'Check logs console details.'}`, 'error');
              loadRunsList();
            }
            
            progressBar.style.width = `${pct}%`;
            progressLabel.textContent = `${pct}%`;
          }
        } catch (e) {
          console.error('Failed to poll status API:', e);
        }
      }, 2000);
    }

    // Submit new generation job
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      banner.classList.add('hidden');
      
      const [providerVal, modelVal] = providerSelect.value.split(':');
      const payload = {
        keyword: keywordInput.value.trim(),
        category: categorySelect.value,
        provider: providerVal,
        model: modelVal,
        author: authorSelect.value,
        status: statusSelect.value
      };

      toggleFormDisabled(true);
      
      // Setup live terminal view
      consoleCard.classList.remove('hidden');
      consoleEl.textContent = 'Spawning background worker processes...\nWaiting for server handshake...';
      progressBar.style.width = '2%';
      progressLabel.textContent = '2%';

      try {
        const res = await fetch('/api/admin/auto-poster', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (res.ok && data.success && data.runId) {
          consoleEl.textContent += '\nHandshake success. Commencing generation run...';
          pollRunStatus(data.runId);
        } else {
          throw new Error(data.error || 'Server rejected auto-poster request.');
        }
      } catch (err: any) {
        console.error(err);
        toggleFormDisabled(false);
        showBanner(err.message || 'Error occurred starting content generator.', 'error');
      }
    });

    // Refresh button listeners
    document.getElementById('refresh-history-btn')?.addEventListener('click', loadRunsList);

    // Initial Load
    loadRunsList();
  </script>
</AdminLayout>
