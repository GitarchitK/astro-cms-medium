---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import { adminDb } from '../../lib/firebase-admin';

const { category, slug } = Astro.params;

let article: any = null;
let relatedArticles: any[] = [];

// Session check to allow drafts/scheduled previews for Admin
const session = Astro.cookies.get('admin_session');
const isAdmin = session?.value === 'authenticated';

if (adminDb && slug) {
  try {
    const snapshot = await adminDb.collection('articles')
      .where('slug', '==', slug)
      .limit(1)
      .get();

    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      const d = doc.data();
      const pDate = d.publish_date?.toDate?.() || null;
      const uDate = d.updated_date?.toDate?.() || pDate;
      const now = new Date();

      // Check access permission: public can only view published and active articles
      const isPublished = d.status === 'published';
      const isPastPublish = pDate && pDate <= now;

      if (isAdmin || (isPublished && isPastPublish)) {
        const contentStr = d.content || '';
        
        // Extract title tag content
        const titleMatch = contentStr.match(/<title>([\s\S]*?)<\/title>/i);
        const parsedMetaTitle = titleMatch ? titleMatch[1].trim() : null;

        // Extract meta description content
        const descMatch = contentStr.match(/<meta\s+name="description"\s+content="([\s\S]*?)"/i) || 
                          contentStr.match(/<meta\s+property="og:description"\s+content="([\s\S]*?)"/i);
        const parsedMetaDesc = descMatch ? descMatch[1].trim() : null;

        article = {
          id: doc.id,
          title: d.title || '',
          slug: d.slug || doc.id,
          excerpt: d.excerpt || '',
          content: d.content || '',
          metaTitle: parsedMetaTitle || d.meta_title || d.title,
          metaDescription: parsedMetaDesc || d.meta_description || d.excerpt || '',
          featuredImage: d.featured_image || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200',
          category: d.category || 'AI Tools',
          categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
          author: d.author || 'Mershal Editorial Team',
          publishDate: pDate,
          modifiedDate: uDate,
          readingTime: d.readingTime || 5,
          tags: d.tags || [],
          status: d.status || 'published',
          faq_items: d.faq_items || [],
          isCustomHtml: !!d.isCustomHtml || d.content?.toLowerCase().includes('<html') || d.content?.toLowerCase().includes('<!doctype')
        };

        // Redirect to the correct category slug if it doesn't match the URL parameter
        if (article.categorySlug !== category) {
          return Astro.redirect(`/${article.categorySlug}/${article.slug}`, 301);
        }

        // Fetch related articles from same category (exclude current)
        const relatedSnapshot = await adminDb.collection('articles')
          .where('category', '==', article.category)
          .where('status', '==', 'published')
          .limit(4)
          .get();

        relatedArticles = relatedSnapshot.docs
          .map(rdoc => {
            const rd = rdoc.data();
            return {
              id: rdoc.id,
              slug: rd.slug || rdoc.id,
              title: rd.title || '',
              category: rd.category || 'AI Tools',
              categorySlug: (rd.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
              featuredImage: rd.featured_image || '',
              readingTime: rd.readingTime || 5,
              publishDate: rd.publish_date?.toDate?.() || null
            };
          })
          .filter(art => art.id !== article.id && art.publishDate && art.publishDate <= now)
          .slice(0, 3);
      }
    }
  } catch (e) {
    console.error('Error fetching article detail:', e);
  }
}

if (!article) return Astro.redirect('/404');

// Automatic contextual internal links to build topics clusters
function injectContextualLinks(contentHtml: string, currentSlug: string) {
  const linkMappings = [
    { term: 'AI Tools', url: '/category/ai-tools' },
    { term: 'Technology Guides', url: '/category/technology-guides' },
    { term: 'Software Reviews', url: '/category/software-reviews' },
    { term: 'SEO & Blogging', url: '/category/seo-blogging' },
    { term: 'Web Development', url: '/category/web-development' },
    { term: 'Productivity', url: '/category/productivity' },
    { term: 'Freelancing', url: '/category/freelancing' },
    { term: 'Side Hustles', url: '/category/side-hustles' },
    { term: 'Remote Work', url: '/category/remote-work' },
    { term: 'Startup Stories', url: '/category/startup-stories' }
  ];

  let modifiedHtml = contentHtml;

  for (const mapping of linkMappings) {
    if (mapping.url.includes(currentSlug)) continue;

    // Matches paragraphs to inject links securely inside content blocks
    const paragraphRegex = /<p>([\s\S]*?)<\/p>/gi;
    let match;
    let replaced = false;

    paragraphRegex.lastIndex = 0;

    while ((match = paragraphRegex.exec(contentHtml)) !== null && !replaced) {
      const paragraphContent = match[1];
      
      // Do not inject if a link is already present inside paragraph or term isn't there
      if (paragraphContent.toLowerCase().includes('href=') || !paragraphContent.toLowerCase().includes(mapping.term.toLowerCase())) {
        continue;
      }

      const termRegex = new RegExp(`\\b(${mapping.term})\\b`, 'i');
      if (termRegex.test(paragraphContent)) {
        const newParagraph = paragraphContent.replace(termRegex, `<a href="${mapping.url}" class="text-indigo-650 dark:text-indigo-405 font-bold hover:underline">$1</a>`);
        modifiedHtml = modifiedHtml.replace(match[0], `<p>${newParagraph}</p>`);
        replaced = true;
      }
    }
  }

  return modifiedHtml;
}

const adInjectedContent = injectContextualLinks(article.content, article.slug);
const shortDate = article.publishDate ? article.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
const shortModifiedDate = article.modifiedDate ? article.modifiedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
const isUpdated = article.modifiedDate && article.publishDate && article.modifiedDate.getTime() > article.publishDate.getTime() + 86400000;

// Dynamic FAQ builder helper
function detectFaqsFromHtml(html: string) {
  const faqs: { question: string; answer: string }[] = [];
  const qMatches = [...html.matchAll(/<h4>Q:\s*(.*?)<\/h4>\s*<p>A:\s*(.*?)<\/p>/gi)];
  for (const match of qMatches) {
    faqs.push({ question: match[1], answer: match[2] });
  }
  return faqs;
}

const detectedFaqs = detectFaqsFromHtml(article.content);
const finalFaqs = [...(article.faq_items || []), ...detectedFaqs];
const seenQuestions = new Set();
const uniqueFaqs = finalFaqs.filter(faq => {
  const q = faq.question?.trim().toLowerCase();
  if (!q || seenQuestions.has(q)) return false;
  seenQuestions.add(q);
  return true;
});
---

<Layout
  title={article.metaTitle}
  description={article.metaDescription}
  image={article.featuredImage}
  type="article"
  author={article.author}
  publishedAt={article.publishDate?.toISOString()}
>
  <!-- SEO JSON-LD Consolidate Schema -->
  <Fragment slot="head">
    <link rel="preload" as="image" href={article.featuredImage} fetchpriority="high" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://mershal.in/#organization",
          "name": "Mershal",
          "url": "https://mershal.in",
          "logo": {
            "@type": "ImageObject",
            "url": "https://mershal.in/logo.png"
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://mershal.in/#website",
          "url": "https://mershal.in",
          "name": "Mershal",
          "publisher": {
            "@id": "https://mershal.in/#organization"
          }
        },
        {
          "@type": "BreadcrumbList",
          "@id": `https://mershal.in/${article.categorySlug}/${article.slug}/#breadcrumb`,
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://mershal.in/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": article.category,
              "item": `https://mershal.in/category/${article.categorySlug}`
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": article.title,
              "item": `https://mershal.in/${article.categorySlug}/${article.slug}`
            }
          ]
        },
        {
          "@type": "WebPage",
          "@id": `https://mershal.in/${article.categorySlug}/${article.slug}/#webpage`,
          "url": `https://mershal.in/${article.categorySlug}/${article.slug}`,
          "name": article.title,
          "isPartOf": {
            "@id": "https://mershal.in/#website"
          },
          "speakable": {
            "@type": "SpeakableSpecification",
            "cssSelector": [
              ".article-title",
              ".article-excerpt"
            ]
          }
        },
        {
          "@type": "BlogPosting",
          "@id": `https://mershal.in/${article.categorySlug}/${article.slug}/#article`,
          "isPartOf": {
            "@id": "https://mershal.in/#website"
          },
          "headline": article.title,
          "description": article.excerpt,
          "image": {
            "@type": "ImageObject",
            "url": article.featuredImage
          },
          "datePublished": article.publishDate?.toISOString(),
          "dateModified": article.modifiedDate?.toISOString(),
          "author": {
            "@type": "Person",
            "name": article.author,
            "jobTitle": "Contributor",
            "description": "Expert reviewer and strategist writing for Mershal.",
            "url": `https://mershal.in/author/${article.author.toLowerCase().replace(/\s+/g, '-')}`
          },
          "publisher": {
            "@id": "https://mershal.in/#organization"
          },
          "mainEntityOfPage": `https://mershal.in/${article.categorySlug}/${article.slug}`
        },
        ...(uniqueFaqs.length > 0 ? [{
          "@type": "FAQPage",
          "@id": `https://mershal.in/${article.categorySlug}/${article.slug}/#faq`,
          "mainEntity": uniqueFaqs.map(f => ({
            "@type": "Question",
            "name": f.question,
            "acceptedAnswer": {
              "@type": "Answer",
              "text": f.answer
            }
          }))
        }] : [])
      ]
    })} />
  </Fragment>

  <Header />

  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[4px] bg-gradient-to-r from-indigo-650 via-violet-500 to-pink-500 w-0 z-[9999] transition-[width] duration-75 ease-out shadow-sm"></div>

  <main class="bg-white dark:bg-slate-900 min-h-screen pb-16 font-sans transition-colors duration-300 animate-fade-in-up">
    
    <!-- Breadcrumb Header -->
    <div class="border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/10">
      <div class="container mx-auto px-4 max-w-6xl">
        <Breadcrumbs category={article.category} categorySlug={article.categorySlug} title={article.title} />
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-6xl py-8 md:py-12">
      <!-- Admin preview warning -->
      {article.status === 'draft' && (
        <div class="mb-6 p-4 bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-900 text-amber-700 dark:text-amber-400 rounded-xl text-xs font-bold uppercase tracking-wider font-outfit select-none">
          ⚠️ Viewing draft preview. This article is not visible to the public.
        </div>
      )}
      {article.publishDate && article.publishDate > new Date() && (
        <div class="mb-6 p-4 bg-indigo-50 dark:bg-indigo-950/20 border border-indigo-200 dark:border-indigo-900 text-indigo-755 dark:text-indigo-400 rounded-xl text-xs font-bold uppercase tracking-wider font-outfit select-none">
          ⚡ Scheduled Post: This article will automatically publish on {article.publishDate.toLocaleString()}.
        </div>
      )}

      <div class={`grid grid-cols-1 ${article.isCustomHtml ? '' : 'lg:grid-cols-[1fr_300px]'} gap-10`}>
        
        <!-- Left: Main Article Content -->
        <div class={`relative ${article.isCustomHtml ? 'max-w-none' : 'max-w-[700px]'} mx-auto w-full min-w-0`}>
          
          <article class="min-w-0 w-full px-1 md:px-0">
            {article.isCustomHtml ? (
              <>
                <!-- Shadow DOM container for Custom HTML/CSS Content to encapsulate styles -->
                <div id="custom-html-wrapper" class="w-full">
                  <template id="custom-html-template" set:html={adInjectedContent}></template>
                  <div id="shadow-host"></div>
                </div>
                <script is:inline>
                  (function() {
                    const host = document.getElementById('shadow-host');
                    const template = document.getElementById('custom-html-template');
                    if (host && template) {
                      const shadow = host.attachShadow({ mode: 'open' });
                      shadow.appendChild(template.content.cloneNode(true));
                    }
                  })();
                </script>
              </>
            ) : (
              <>
                <header class="mb-8">
                  <h1 class="article-title text-3xl md:text-4xl lg:text-[2.5rem] font-serif font-black text-slate-900 dark:text-white leading-[1.15] mb-5 tracking-tight">
                    {article.title}
                  </h1>
                  
                  <p class="article-excerpt text-lg md:text-xl text-slate-500 dark:text-slate-400 leading-relaxed font-light mb-6">
                    {article.excerpt}
                  </p>
                  
                  <!-- Author Byline Row -->
                  <div class="flex flex-wrap items-center gap-3 py-4 border-y border-slate-150 dark:border-slate-800/80 text-[13px] text-slate-500 dark:text-slate-450 font-sans">
                    <div class="w-9 h-9 rounded-xl bg-indigo-100 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 flex items-center justify-center font-black text-xs uppercase border border-indigo-200/30">
                      {article.author.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
                    </div>
                    
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 ml-1">
                      <span class="font-bold text-slate-800 dark:text-slate-200">{article.author}</span>
                      <span class="text-slate-350 dark:text-slate-700 select-none">·</span>
                      {isUpdated ? (
                        <span>Updated: <time datetime={article.modifiedDate?.toISOString()}>{shortModifiedDate}</time></span>
                      ) : (
                        <span>Published: <time datetime={article.publishDate?.toISOString()}>{shortDate}</time></span>
                      )}
                      <span class="text-slate-350 dark:text-slate-700 select-none">·</span>
                      <span class="flex items-center gap-1 font-medium">
                        {article.readingTime} min read
                      </span>
                    </div>
                    
                    <div class="sm:ml-auto flex items-center gap-2 pt-2 sm:pt-0">
                      <button id="copy-url-btn" class="px-3.5 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-750 text-slate-600 dark:text-slate-300 rounded-lg text-[10px] font-black uppercase tracking-wider transition border border-slate-200/40 dark:border-slate-700/60 cursor-pointer">
                        Copy Link
                      </button>
                    </div>
                  </div>
                </header>

                <!-- Featured Image -->
                <div class="mb-10 relative rounded-2xl overflow-hidden border border-slate-200/50 dark:border-slate-800/60 shadow-sm aspect-[16/9] bg-slate-105 dark:bg-slate-950">
                  <Image
                    src={article.featuredImage}
                    alt={article.title}
                    width={800}
                    height={450}
                    widths={[400, 800, 1200]}
                    sizes="(max-width: 800px) 100vw, 800px"
                    class="w-full h-full object-cover"
                    loading="eager"
                    fetchpriority="high"
                  />
                  <div class="absolute bottom-4 left-4 z-10 select-none">
                    <span class="inline-block bg-slate-950/75 dark:bg-slate-900/80 backdrop-blur-sm text-white text-[12px] font-black uppercase tracking-wider px-3 py-1.5 rounded-xl shadow-sm">
                      {article.category}
                    </span>
                  </div>
                </div>

                <!-- Mobile Table of Contents Toggle -->
                <div id="mobile-toc-box" class="lg:hidden mb-8 bg-slate-50 dark:bg-slate-900/50 border border-slate-200/50 dark:border-slate-800/60 rounded-2xl overflow-hidden hidden shadow-sm">
                  <button id="mobile-toc-toggle" class="w-full flex items-center justify-between px-5 py-4 font-bold text-slate-800 dark:text-slate-200 text-sm hover:bg-slate-100/50 transition">
                    <span>Table of Contents</span>
                    <svg id="mobile-toc-arrow" class="w-4 h-4 text-slate-500 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div id="mobile-toc-content" class="px-5 pb-4 hidden border-t border-slate-150 dark:border-slate-800/80 pt-3">
                    <nav id="mobile-toc-nav" class="space-y-2 text-xs font-semibold text-slate-550 dark:text-slate-400"></nav>
                  </div>
                </div>

                <!-- Content Area -->
                <div class="article-content max-w-none text-slate-700 dark:text-slate-300" set:html={adInjectedContent} />

                <!-- Tags list -->
                {article.tags && article.tags.length > 0 && (
                  <div class="mt-10 pt-6 border-t border-slate-150 dark:border-slate-800/80 flex flex-wrap items-center gap-2">
                    <span class="text-xs font-extrabold uppercase tracking-wider text-slate-400 dark:text-slate-500 mr-2 select-none">Tags:</span>
                    <div class="flex flex-wrap gap-2">
                      {article.tags.map((tag: string) => (
                        <a href={`/search?q=${tag}`} class="px-3.5 py-1 bg-slate-105 dark:bg-slate-850 text-slate-500 dark:text-slate-400 text-[13px] rounded-full border border-slate-200/50 dark:border-slate-850/80 hover:bg-indigo-50 dark:hover:bg-indigo-900/25 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all font-semibold">
                          #{tag}
                        </a>
                      ))}
                    </div>
                  </div>
                )}

                <!-- Author Card -->
                <AuthorCard name={article.author} />

                <!-- Dynamic FAQ Accodion -->
                {uniqueFaqs.length > 0 && (
                  <div class="mt-12 pt-8 border-t border-slate-150 dark:border-slate-800/80 space-y-4">
                    <h3 class="text-lg font-black font-serif text-slate-900 dark:text-white uppercase tracking-wide">Frequently Asked Questions</h3>
                    <div class="space-y-3">
                      {uniqueFaqs.map((faq: any, idx: number) => (
                        <details class="group bg-slate-50 dark:bg-slate-900/40 border border-slate-200/40 dark:border-slate-800/80 rounded-2xl p-5 [&_summary::-webkit-details-marker]:hidden cursor-pointer" open={idx === 0}>
                          <summary class="flex items-center justify-between gap-4 font-bold text-sm text-slate-800 dark:text-slate-200">
                            <span>{faq.question}</span>
                            <svg class="w-4 h-4 text-slate-550 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                          </summary>
                          <p class="mt-3 text-xs md:text-sm text-slate-605 dark:text-slate-400 leading-relaxed font-medium pl-1">
                            {faq.answer}
                          </p>
                        </details>
                      ))}
                    </div>
                  </div>
                )}

                <!-- Related Articles Slider -->
                {relatedArticles.length > 0 && (
                  <section class="mt-14 pt-8 border-t border-slate-200 dark:border-slate-800">
                    <h3 class="text-lg font-black font-serif text-slate-900 dark:text-white uppercase tracking-wide mb-6">Related Guides & Reviews</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                      {relatedArticles.map((rel: any) => (
                        <a href={`/${rel.categorySlug}/${rel.slug}`} class="group flex flex-col bg-white dark:bg-slate-900 rounded-xl border border-slate-200/50 dark:border-slate-850/80 overflow-hidden shadow-sm hover:border-indigo-500/30 transition-all duration-200">
                          <div class="aspect-[16/9] w-full overflow-hidden border-b border-slate-100 dark:border-slate-800">
                            <Image src={rel.featuredImage || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=400'} alt={rel.title} width={360} height={200} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-102" />
                          </div>
                          <div class="p-4 flex flex-col flex-1 justify-between gap-3">
                            <div>
                              <span class="inline-block text-[10px] font-extrabold uppercase tracking-wider text-indigo-600 dark:text-indigo-400 mb-1.5">{rel.category}</span>
                              <h4 class="text-[14px] font-bold text-slate-800 dark:text-slate-200 line-clamp-2 leading-[1.4] group-hover:text-indigo-650 dark:group-hover:text-indigo-400 transition-colors">{rel.title}</h4>
                            </div>
                            <div class="flex items-center gap-1.5 text-[10px] text-slate-400 font-bold font-mono">
                              <span>{rel.readingTime} min read</span>
                            </div>
                          </div>
                        </a>
                      ))}
                    </div>
                  </section>
                )}
              </>
            )}

          </article>
        </div>

        <!-- Right: Sticky Sidebar TOC -->
        {!article.isCustomHtml && (
          <aside class="hidden lg:block w-[300px]">
            <div class="sticky top-24 space-y-8">
              <div id="toc-box" class="bg-slate-50/50 dark:bg-slate-900/30 rounded-2xl p-5 border border-slate-200/50 dark:border-slate-800/80 shadow-sm hidden">
                <h3 class="text-xs uppercase tracking-widest font-black text-slate-900 dark:text-white mb-4 font-sans">Table of Contents</h3>
                <nav id="toc-nav" class="relative pl-3 space-y-3.5 text-xs font-bold text-slate-500 dark:text-slate-400 border-l border-slate-200 dark:border-slate-800"></nav>
              </div>
            </div>
          </aside>
        )}

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Table of Contents generator
  const headings = document.querySelectorAll('.article-content h2, .article-content h3');
  const headingsArray = Array.from(headings);
  
  if (headingsArray.length > 1) {
    const tocBox = document.getElementById('toc-box');
    const tocNav = document.getElementById('toc-nav');
    const mobileTocBox = document.getElementById('mobile-toc-box');
    const mobileTocNav = document.getElementById('mobile-toc-nav');
    const mobileTocToggle = document.getElementById('mobile-toc-toggle');
    const mobileTocContent = document.getElementById('mobile-toc-content');
    const mobileTocArrow = document.getElementById('mobile-toc-arrow');

    if (tocBox && tocNav) {
      tocBox.classList.remove('hidden');
    }
    if (mobileTocBox && mobileTocNav) {
      mobileTocBox.classList.remove('hidden');
    }

    headingsArray.forEach((heading, idx) => {
      const id = heading.id || `heading-anchor-${idx}`;
      heading.id = id;

      // Desktop link
      if (tocNav) {
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = heading.textContent;
        a.className = heading.tagName === 'H2' 
          ? 'block text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all text-xs font-bold relative -left-[14px] pl-3 border-l-2 border-transparent hover:border-slate-350'
          : 'block text-slate-400 dark:text-slate-500 hover:text-indigo-650 dark:hover:text-indigo-405 transition-all text-[11px] font-bold relative -left-[14px] pl-6 border-l-2 border-transparent hover:border-slate-300';
        tocNav.appendChild(a);
      }

      // Mobile link
      if (mobileTocNav) {
        const aMobile = document.createElement('a');
        aMobile.href = `#${id}`;
        aMobile.textContent = heading.textContent;
        aMobile.className = heading.tagName === 'H2' 
          ? 'block text-slate-700 dark:text-slate-300 hover:text-indigo-600 py-1 text-xs font-semibold'
          : 'block pl-3 text-slate-450 dark:text-slate-500 hover:text-indigo-600 py-0.5 text-[11px] font-semibold';
        
        aMobile.addEventListener('click', () => {
          mobileTocContent?.classList.add('hidden');
          mobileTocArrow?.classList.remove('rotate-180');
        });
        mobileTocNav.appendChild(aMobile);
      }
    });

    mobileTocToggle?.addEventListener('click', () => {
      mobileTocContent?.classList.toggle('hidden');
      mobileTocArrow?.classList.toggle('rotate-180');
    });

    // Active TOC highlighter
    const observer = new IntersectionObserver(() => {
      let currentActiveId = '';
      headingsArray.forEach(heading => {
        const rect = heading.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.3) {
          currentActiveId = heading.id;
        }
      });

      if (currentActiveId) {
        const links = document.querySelectorAll('#toc-nav a, #mobile-toc-nav a');
        links.forEach(link => {
          if (link.getAttribute('href') === `#${currentActiveId}`) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });
      }
    }, { root: null, rootMargin: '-5% 0px -75% 0px', threshold: [0, 1] });

    headingsArray.forEach(heading => observer.observe(heading));
  }

  // Copy URL logic
  document.getElementById('copy-url-btn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('copy-url-btn') as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy Link'; }, 1500);
  });

  // Reading Progress Bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = progress + '%';
    });
  }
</script>

