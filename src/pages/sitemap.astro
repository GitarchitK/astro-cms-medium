---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { adminDb } from '../lib/firebase-admin';

// 1. Static Pages
const staticPages = [
  { name: 'Home', href: '/' },
  { name: 'All Articles', href: '/articles' },
  { name: 'About Us', href: '/about' },
  { name: 'Contact Us', href: '/contact' },
  { name: 'Privacy Policy', href: '/privacy' },
  { name: 'Terms & Conditions', href: '/terms' },
  { name: 'Disclaimer', href: '/disclaimer' }
];

// 2. Default Built-in Categories
const builtinCategories = [
  { name: 'AI Tools', slug: 'ai-tools', description: 'Reviews, comparison guides, and workflows for generative AI models and automation tools.' },
  { name: 'Technology Guides', slug: 'technology-guides', description: 'Step-by-step guides and instructions on modern tech topics.' },
  { name: 'Freelancing', slug: 'freelancing', description: 'Client acquisition, contract negotiation, pricing models, and gig scaling resources.' },
  { name: 'Remote Work', slug: 'remote-work', description: 'Tips, tools, and best practices for thriving in a distributed working environment.' },
  { name: 'Side Hustles', slug: 'side-hustles', description: 'Practical ideas, strategies, and case studies to build extra income streams.' },
  { name: 'Software Reviews', slug: 'software-reviews', description: 'In-depth analyses, pricing updates, and features comparison of software platforms.' },
  { name: 'SEO & Blogging', slug: 'seo-blogging', description: 'Audits, search optimization, funnel setups, and growth strategies for blogging.' },
  { name: 'Web Development', slug: 'web-development', description: 'Tutorials, libraries, design patterns, and programming guides.' },
  { name: 'Startup Stories', slug: 'startup-stories', description: 'Interviews, funding rounds, lessons learned, and founder profiles.' },
  { name: 'Productivity', slug: 'productivity', description: 'Apps, frameworks, and workflows to optimize daily outputs and scale operations.' }
];

let categories = [...builtinCategories];
let articles: any[] = [];

if (adminDb) {
  try {
    // Fetch custom categories (optimized selection)
    const catSnap = await adminDb.collection('categories')
      .select('name', 'slug', 'description')
      .get();
    if (!catSnap.empty) {
      catSnap.docs.forEach(doc => {
        const d = doc.data();
        if (d.slug && !categories.some(c => c.slug === d.slug)) {
          categories.push({
            name: d.name,
            slug: d.slug,
            description: d.description || 'Custom category for articles on Mershal.'
          });
        }
      });
    }

    // Fetch published articles (optimized selection)
    const snapshot = await adminDb.collection('articles')
      .where('status', '==', 'published')
      .orderBy('publish_date', 'desc')
      .select('title', 'slug', 'category', 'publish_date', 'readingTime')
      .get();

    const now = new Date();
    articles = snapshot.docs.map(doc => {
      const d = doc.data();
      let pDate = null;
      if (d.publish_date) {
        if (typeof d.publish_date.toDate === 'function') {
          pDate = d.publish_date.toDate();
        } else {
          pDate = new Date(d.publish_date);
        }
      }
      return {
        id: doc.id,
        title: d.title || '',
        slug: d.slug || doc.id,
        category: d.category || 'AI Tools',
        categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        publishDate: pDate,
        readingTime: d.readingTime || 5
      };
    })
    .filter(art => art.publishDate && art.publishDate <= now);
  } catch (e) {
    console.error('Error fetching sitemap data:', e);
  }
}

// Group articles by categorySlug
const articlesByCategory = articles.reduce((acc, art) => {
  if (!acc[art.categorySlug]) {
    acc[art.categorySlug] = [];
  }
  acc[art.categorySlug].push(art);
  return acc;
}, {} as Record<string, any[]>);
---

<Layout 
  title="Sitemap — Mershal" 
  description="Explore the complete sitemap of Mershal. Access all articles, guides, categories, and core pages seamlessly."
>
  <Header />

  <main class="min-h-screen py-16 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 font-sans">
    <div class="container mx-auto px-4 max-w-5xl">
      
      <!-- Page Header -->
      <div class="mb-12 text-center">
        <span class="inline-block px-3.5 py-1.5 bg-indigo-50/60 dark:bg-indigo-950/40 text-indigo-650 dark:text-indigo-400 text-[10px] font-black uppercase tracking-widest rounded-full mb-3 select-none">
          Index
        </span>
        <h1 class="text-3xl md:text-5xl font-black font-outfit text-slate-900 dark:text-white tracking-tight">
          Website Sitemap
        </h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-3 max-w-lg mx-auto font-medium">
          A comprehensive overview and index of all sections, categories, and published guides on Mershal.
        </p>
      </div>

      <!-- Search Bar -->
      <div class="mb-12 max-w-lg mx-auto relative group">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-450 dark:text-slate-550 group-focus-within:text-indigo-600 transition-colors">
          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input 
          type="text" 
          id="sitemap-search" 
          placeholder="Filter articles by title..." 
          class="w-full pl-11 pr-10 py-3 bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 border border-slate-200 dark:border-slate-800/80 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-505 transition-all font-semibold text-xs md:text-sm"
        />
        <button 
          id="clear-search" 
          class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 hidden transition-colors"
          aria-label="Clear search"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Content Grid -->
      <div class="space-y-12">
        
        <!-- Section 1: Main Pages -->
        <section id="core-pages-section" class="bg-white dark:bg-slate-900 p-8 rounded-2xl border border-slate-200/50 dark:border-slate-800/80 shadow-sm transition-all duration-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 flex items-center justify-center">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253" />
              </svg>
            </div>
            <h2 class="text-xl font-bold font-outfit text-slate-800 dark:text-white">Core Pages</h2>
          </div>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
            {staticPages.map(page => (
              <a 
                href={page.href} 
                class="flex items-center px-4 py-3 bg-slate-50 dark:bg-slate-950/40 text-slate-700 dark:text-slate-350 hover:bg-indigo-50 dark:hover:bg-indigo-900/25 hover:text-indigo-650 dark:hover:text-indigo-400 font-semibold text-xs rounded-xl border border-slate-150 dark:border-slate-800/80 hover:border-indigo-200/50 dark:hover:border-indigo-900/30 transition-all shadow-sm"
              >
                {page.name}
              </a>
            ))}
          </div>
        </section>

        <!-- Section 2: Articles & Categories Index -->
        <section class="space-y-8">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 flex items-center justify-center">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold font-outfit text-slate-800 dark:text-white">Guides by Category</h2>
          </div>

          <!-- No Results State -->
          <div id="no-results" class="hidden text-center py-16 bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-800/80 rounded-2xl max-w-lg mx-auto shadow-sm">
            <svg class="w-10 h-10 text-slate-400 dark:text-slate-600 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <h3 class="text-slate-800 dark:text-slate-200 text-sm font-bold font-outfit">No matching articles found</h3>
            <p class="text-slate-500 dark:text-slate-500 text-xs font-outfit mt-1">Try adjusting your keywords or search terms.</p>
          </div>

          <div id="categories-container" class="space-y-6">
            {categories.map(cat => {
              const catArticles = articlesByCategory[cat.slug] || [];
              
              return (
                <div 
                  class="category-block bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-800/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-200" 
                  data-category={cat.slug} 
                  data-count={catArticles.length}
                >
                  <!-- Category Header -->
                  <div class="p-6 md:p-8 bg-slate-50/50 dark:bg-slate-900/40 border-b border-slate-100 dark:border-slate-800/80">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                      <div>
                        <h3 class="text-lg font-bold font-outfit text-slate-800 dark:text-white">
                          <a href={`/category/${cat.slug}`} class="hover:text-indigo-650 dark:hover:text-indigo-400 transition-colors">
                            {cat.name}
                          </a>
                        </h3>
                        <p class="text-slate-500 dark:text-slate-400 text-[11px] mt-1.5 max-w-2xl leading-relaxed">
                          {cat.description}
                        </p>
                      </div>
                      <span class="inline-flex self-start sm:self-center px-3 py-1 bg-indigo-50 dark:bg-indigo-950/60 text-indigo-650 dark:text-indigo-400 text-[10px] font-extrabold uppercase tracking-wider rounded-xl">
                        {catArticles.length} {catArticles.length === 1 ? 'Article' : 'Articles'}
                      </span>
                    </div>
                  </div>

                  <!-- Category Articles List -->
                  <div class="p-6 md:p-8">
                    {catArticles.length > 0 ? (
                      <ul class="space-y-4">
                        {catArticles.map((art: any) => (
                          <li 
                            class="article-item flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-slate-100 dark:border-slate-800/60 pb-3 last:border-0 last:pb-0"
                            data-title={art.title.toLowerCase()}
                          >
                            <a 
                              href={`/${art.categorySlug}/${art.slug}`} 
                              class="text-[13px] md:text-sm font-semibold text-slate-700 dark:text-slate-350 hover:text-indigo-650 dark:hover:text-indigo-400 leading-snug transition-colors"
                            >
                              {art.title}
                            </a>
                            
                            <div class="flex items-center gap-2 text-[10px] text-slate-400 font-bold tracking-wide select-none min-w-max">
                              <span>{art.readingTime} min read</span>
                              <span>·</span>
                              <time datetime={art.publishDate?.toISOString()}>
                                {art.publishDate?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                              </time>
                            </div>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <div class="empty-category-state">
                        <p class="text-xs text-slate-400 dark:text-slate-500 italic">
                          No articles published in this category yet.
                        </p>
                      </div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const searchInput = document.getElementById('sitemap-search') as HTMLInputElement | null;
  const clearButton = document.getElementById('clear-search') as HTMLButtonElement | null;
  const categoryBlocks = document.querySelectorAll('.category-block');
  const noResultsBlock = document.getElementById('no-results');
  const corePagesSection = document.getElementById('core-pages-section');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      
      if (clearButton) {
        if (query.length > 0) {
          clearButton.classList.remove('hidden');
        } else {
          clearButton.classList.add('hidden');
        }
      }

      let totalVisibleArticles = 0;

      categoryBlocks.forEach((block) => {
        const articles = block.querySelectorAll('.article-item');
        let visibleInBlock = 0;

        articles.forEach((item) => {
          const title = (item.getAttribute('data-title') || '').toLowerCase();
          const element = item as HTMLElement;
          if (title.includes(query)) {
            element.style.display = '';
            visibleInBlock++;
          } else {
            element.style.display = 'none';
          }
        });

        const emptyState = block.querySelector('.empty-category-state') as HTMLElement | null;
        const elementBlock = block as HTMLElement;

        if (query.length > 0) {
          if (visibleInBlock === 0) {
            elementBlock.style.display = 'none';
          } else {
            elementBlock.style.display = '';
            if (emptyState) emptyState.style.display = 'none';
            totalVisibleArticles += visibleInBlock;
          }
        } else {
          // Restore default view
          elementBlock.style.display = '';
          const totalArticles = parseInt(block.getAttribute('data-count') || '0', 10);
          if (totalArticles === 0) {
            if (emptyState) emptyState.style.display = '';
          } else {
            totalVisibleArticles += totalArticles;
          }
        }
      });

      // Show/hide core pages section when searching
      if (corePagesSection) {
        if (query.length > 0) {
          corePagesSection.style.display = 'none';
        } else {
          corePagesSection.style.display = '';
        }
      }

      // Show/hide global no results state
      if (noResultsBlock) {
        if (query.length > 0 && totalVisibleArticles === 0) {
          noResultsBlock.classList.remove('hidden');
        } else {
          noResultsBlock.classList.add('hidden');
        }
      }
    });
  }

  if (clearButton && searchInput) {
    clearButton.addEventListener('click', () => {
      searchInput.value = '';
      searchInput.dispatchEvent(new Event('input'));
      searchInput.focus();
    });
  }
</script>
