---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { adminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

interface Author {
  name: string;
  slug: string;
  role: string;
  bio: string;
  avatar?: string;
  twitter?: string;
  linkedin?: string;
}

const AUTHORS: Record<string, Author> = {
  'editorial-team': {
    name: 'Editorial Team',
    slug: 'editorial-team',
    role: 'Editorial Board',
    bio: 'The core editorial team of Mershal, delivering high-quality, researched, and vetted guides on technology, software, side hustles, and growth.',
    avatar: '',
    twitter: 'https://twitter.com/mershal_in',
    linkedin: 'https://linkedin.com/company/mershal_in'
  },
  'mershal-editorial-team': {
    name: 'Mershal Editorial Team',
    slug: 'mershal-editorial-team',
    role: 'Editorial Board',
    bio: 'The core editorial team of Mershal, delivering high-quality, researched, and vetted guides on technology, software, side hustles, and growth.',
    avatar: '',
    twitter: 'https://twitter.com/mershal_in',
    linkedin: 'https://linkedin.com/company/mershal_in'
  },
  'admin': {
    name: 'Admin',
    slug: 'admin',
    role: 'System Administrator',
    bio: 'Lead system administrator and content publisher at Mershal, ensuring operational excellence across all SaaS blueprints and tutorials.',
    avatar: '',
    twitter: 'https://twitter.com/mershal_in',
    linkedin: 'https://linkedin.com/company/mershal_in'
  },
  'editor': {
    name: 'Editor',
    slug: 'editor',
    role: 'Senior Editor',
    bio: 'Expert editor curating the best practices in AI tooling, automation hacks, and digital asset scaling.',
    avatar: '',
    twitter: 'https://twitter.com/mershal_in',
    linkedin: 'https://linkedin.com/company/mershal_in'
  }
};

const currentAuthor = AUTHORS[slug] || {
  name: slug.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' '),
  slug: slug,
  role: 'Contributing Writer',
  bio: `A professional writer contributing deep-dive guides, analysis, and reviews to the Mershal publishing platform.`,
  avatar: '',
  twitter: '#',
  linkedin: '#'
};

let articles: any[] = [];

if (adminDb) {
  try {
    // Try exact author name query first
    let snapshot = await adminDb.collection('articles')
      .where('author', '==', currentAuthor.name)
      .where('status', '==', 'published')
      .orderBy('publish_date', 'desc')
      .get();

    // If no articles found, we can also try matching by standard fallbacks if currentAuthor.name is "Editorial Team" or "Mershal Editorial Team"
    if (snapshot.empty && (currentAuthor.slug === 'editorial-team' || currentAuthor.slug === 'mershal-editorial-team')) {
      const altName = currentAuthor.slug === 'editorial-team' ? 'Mershal Editorial Team' : 'Editorial Team';
      snapshot = await adminDb.collection('articles')
        .where('author', '==', altName)
        .where('status', '==', 'published')
        .orderBy('publish_date', 'desc')
        .get();
    }

    const now = new Date();
    articles = snapshot.docs.map(doc => {
      const d = doc.data();
      return {
        id: doc.id,
        slug: d.slug || doc.id,
        title: d.title || '',
        excerpt: d.excerpt || '',
        featuredImage: d.featured_image || '',
        category: d.category || 'AI Tools',
        categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        author: d.author || currentAuthor.name,
        publishDate: d.publish_date?.toDate?.() || null,
        readingTime: d.readingTime || 5
      };
    })
    .filter(art => art.publishDate && art.publishDate <= now);
  } catch (e) {
    console.error('Error fetching author page articles:', e);
  }
}

// Initials fallback
const initials = currentAuthor.name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
---

<Layout 
  title={`Articles by ${currentAuthor.name} — Mershal`} 
  description={`Read all professional guides, technology reviews, and growth strategies written by ${currentAuthor.name} on Mershal.`}
>
  <Header />

  <main class="min-h-screen py-12 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 font-sans">
    <div class="container mx-auto px-4 max-w-7xl">
      
      <!-- Author Profile Header Card -->
      <div class="max-w-4xl mx-auto mb-16 bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-850/80 rounded-3xl p-8 md:p-12 shadow-sm flex flex-col md:flex-row items-center md:items-start gap-8 text-center md:text-left relative overflow-hidden">
        <!-- Graphic abstract details in cards -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(99,102,241,0.03),transparent_40%)] pointer-events-none"></div>
        
        {currentAuthor.avatar ? (
          <Image src={currentAuthor.avatar} alt={currentAuthor.name} width={96} height={96} class="w-24 h-24 rounded-3xl object-cover border-4 border-slate-50 dark:border-slate-800 shadow-md flex-shrink-0" />
        ) : (
          <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-indigo-650 via-indigo-650 to-violet-600 flex items-center justify-center text-white font-black text-3xl shadow-md flex-shrink-0">
            {initials}
          </div>
        )}
        
        <div class="flex-1 space-y-4">
          <div>
            <span class="inline-block px-3 py-1 bg-indigo-50 dark:bg-indigo-950/40 text-indigo-605 dark:text-indigo-400 text-[10px] font-black uppercase tracking-widest rounded-full mb-2">Author Profile</span>
            <h1 class="text-3xl font-black font-outfit text-slate-900 dark:text-white tracking-tight">{currentAuthor.name}</h1>
            <p class="text-sm font-bold text-indigo-600 dark:text-indigo-405 mt-1">{currentAuthor.role}</p>
          </div>
          
          <p class="text-slate-500 dark:text-slate-400 text-sm md:text-base leading-relaxed max-w-2xl font-medium">
            {currentAuthor.bio}
          </p>
          
          <!-- Social & Stats Row -->
          <div class="flex flex-wrap gap-4 items-center justify-center md:justify-start pt-2 border-t border-slate-100 dark:border-slate-850/80 mt-4">
            {currentAuthor.twitter && currentAuthor.twitter !== '#' && (
              <a href={currentAuthor.twitter} target="_blank" rel="noopener noreferrer" class="text-slate-405 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 text-xs font-bold transition-colors">
                Twitter
              </a>
            )}
            {currentAuthor.twitter && currentAuthor.twitter !== '#' && currentAuthor.linkedin && currentAuthor.linkedin !== '#' && (
              <span class="text-slate-200 dark:text-slate-800">|</span>
            )}
            {currentAuthor.linkedin && currentAuthor.linkedin !== '#' && (
              <a href={currentAuthor.linkedin} target="_blank" rel="noopener noreferrer" class="text-slate-405 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 text-xs font-bold transition-colors">
                LinkedIn
              </a>
            )}
            
            <div class="md:ml-auto flex items-center gap-1.5 text-xs text-slate-400 dark:text-slate-500 font-bold">
              <span>📚 {articles.length} {articles.length === 1 ? 'article' : 'articles'} published</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Articles section -->
      <div class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-black font-outfit text-slate-900 dark:text-white mb-8 tracking-tight flex items-center gap-2">
          <span>Articles Written by {currentAuthor.name}</span>
          <span class="h-[2px] bg-slate-200 dark:bg-slate-850/80 flex-1"></span>
        </h2>

        {articles.length > 0 ? (
          <div class="max-w-4xl mx-auto space-y-4 divide-y divide-slate-100 dark:divide-slate-900">
            {articles.map(art => (
              <ArticleCard
                id={art.id}
                slug={art.slug}
                title={art.title}
                excerpt={art.excerpt}
                imageUrl={art.featuredImage}
                category={art.category}
                categorySlug={art.categorySlug}
                author={art.author}
                publishDate={art.publishDate}
                readingTime={art.readingTime}
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-20 bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-850/80 rounded-2xl max-w-lg mx-auto shadow-sm">
            <svg class="w-12 h-12 text-slate-450 mx-auto mb-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
            <h3 class="text-slate-800 dark:text-slate-200 text-base font-bold font-outfit">No articles published yet</h3>
            <p class="text-slate-500 dark:text-slate-500 text-xs font-outfit mt-1">This author hasn't published any articles on the platform yet.</p>
          </div>
        )}
      </div>

    </div>
  </main>

  <Footer />
</Layout>
