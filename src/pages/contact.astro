---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Contact Us — Mershal" 
  description="Have a question, feedback, or a partnership proposal? Send us a message and the Mershal team will get back to you shortly."
>
  <Header />

  <main class="min-h-screen bg-white dark:bg-slate-950 transition-colors duration-200 font-sans py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-xl">
      
      <!-- Typographic Header Section -->
      <header class="space-y-4 pb-10 border-b border-slate-100 dark:border-slate-900">
        <span class="text-xs uppercase font-bold tracking-widest text-slate-400 dark:text-slate-500 font-mono">Inquiries</span>
        <h1 class="text-3xl md:text-5xl font-serif font-black text-slate-900 dark:text-white leading-tight tracking-tight">
          Contact Mershal
        </h1>
        <p class="text-sm md:text-base font-serif text-slate-500 dark:text-slate-400 leading-relaxed">
          For general feedback, corrections, advertising slots, or product review pitches, complete the form below or write directly to <a href="mailto:admin@mershal.in" class="text-slate-900 dark:text-white underline font-semibold">admin@mershal.in</a>.
        </p>
      </header>

      <!-- Minimalist Contact Form -->
      <div class="py-10">
        <form id="contact-form" class="space-y-8">
          <div id="contact-alert" class="hidden p-4 rounded-lg text-xs font-semibold font-mono border"></div>

          <div class="space-y-1">
            <label for="name" class="block text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-slate-500 font-mono">Your Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              placeholder="E.g. John Doe"
              class="w-full bg-transparent border-b border-t-0 border-x-0 border-slate-200 dark:border-slate-800 text-slate-800 dark:text-white text-sm py-2 focus:outline-none focus:border-slate-900 dark:focus:border-white transition-colors placeholder-slate-300 dark:placeholder-slate-700 font-medium" 
            />
          </div>

          <div class="space-y-1">
            <label for="email" class="block text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-slate-500 font-mono">Email Address</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              placeholder="you@example.com"
              class="w-full bg-transparent border-b border-t-0 border-x-0 border-slate-200 dark:border-slate-800 text-slate-800 dark:text-white text-sm py-2 focus:outline-none focus:border-slate-900 dark:focus:border-white transition-colors placeholder-slate-300 dark:placeholder-slate-700 font-medium" 
            />
          </div>

          <div class="space-y-1">
            <label for="subject" class="block text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-slate-500 font-mono">Subject</label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              placeholder="General Inquiry / Sponsored Pitch"
              class="w-full bg-transparent border-b border-t-0 border-x-0 border-slate-200 dark:border-slate-800 text-slate-800 dark:text-white text-sm py-2 focus:outline-none focus:border-slate-900 dark:focus:border-white transition-colors placeholder-slate-300 dark:placeholder-slate-700 font-medium" 
            />
          </div>

          <div class="space-y-1">
            <label for="message" class="block text-[10px] uppercase font-bold tracking-wider text-slate-400 dark:text-slate-500 font-mono">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required
              placeholder="Write your details here..."
              class="w-full bg-transparent border-b border-t-0 border-x-0 border-slate-200 dark:border-slate-800 text-slate-800 dark:text-white text-sm py-2 focus:outline-none focus:border-slate-900 dark:focus:border-white resize-none transition-colors placeholder-slate-300 dark:placeholder-slate-700 font-medium"
            ></textarea>
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="bg-slate-900 hover:bg-slate-800 dark:bg-white dark:text-black dark:hover:bg-slate-100 text-white font-bold text-xs uppercase tracking-wider px-6 py-3 rounded-full transition-all cursor-pointer flex items-center justify-center select-none"
          >
            <span>Send Message</span>
          </button>
        </form>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const alertBox = document.getElementById('contact-alert');
  const submitBtn = document.getElementById('submit-btn');

  if (form && alertBox && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitText = submitBtn.querySelector('span');
      if (submitText) submitText.innerText = 'Sending...';
      submitBtn.setAttribute('disabled', 'true');
      alertBox.className = 'hidden';

      const formData = new FormData(form);
      const payload = {
        name: formData.get('name'),
        email: formData.get('email'),
        subject: formData.get('subject'),
        message: formData.get('message')
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (res.ok && data.success) {
          alertBox.className = 'p-4 rounded-lg text-xs font-semibold font-mono border bg-emerald-50 dark:bg-emerald-950/20 border-emerald-200 dark:border-emerald-900 text-emerald-800 dark:text-emerald-400 block mb-5';
          alertBox.innerText = '✓ Thank you. Your message has been sent successfully.';
          form.reset();
        } else {
          throw new Error(data.error || 'Server error.');
        }
      } catch (err: any) {
        alertBox.className = 'p-4 rounded-lg text-xs font-semibold font-mono border bg-rose-50 dark:bg-rose-950/20 border-rose-250 dark:border-rose-900 text-rose-800 dark:text-rose-400 block mb-5';
        alertBox.innerText = err.message || '✗ Error occurred while sending. Please try again.';
      } finally {
        if (submitText) submitText.innerText = 'Send Message';
        submitBtn.removeAttribute('disabled');
      }
    });
  }
</script>
